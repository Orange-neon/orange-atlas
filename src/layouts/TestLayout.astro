---
interface Props {
  title: string;
  duration: number;
  difficulty: string;
  description: string;
  examCode?: string;
  questionCount?: number;
  sourceCount?: number;
  infographicTitle?: string;
  infographicSrc?: string;
  audioTitle?: string;
  audioDescription?: string;
  audioSrc?: string;
}

const {
  title,
  duration,
  difficulty,
  description,
  examCode,
  questionCount,
  sourceCount,
  infographicTitle,
  infographicSrc,
  audioTitle,
  audioDescription,
  audioSrc,
} = Astro.props;
const pageTitle = `${title} | Orange Atlas`;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <link rel="icon" href="/orange-atlas/assets/orangeAtlas.png" type="image/png" />
    <style is:global>
      @import url("https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap");

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg: #06060c;
        --s1: #0f0f18;
        --s2: #15151f;
        --border: rgba(255, 255, 255, 0.07);
        --text: #ccccd8;
        --dim: #3e3e52;
        --accent: #a78bfa;
        --accentd: #7c3aed;
        --green: #34d399;
        --red: #f87171;
        --warn: #fb923c;
        --teal: #22d3ee;
      }

      html { scroll-behavior: smooth; }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: "Inter", sans-serif;
        font-size: 15px;
        line-height: 1.65;
        min-height: 100vh;
        overflow-x: hidden;
      }

      .screen { min-height: 100vh; display: flex; flex-direction: column; }

      #s-landing {
        align-items: center;
        justify-content: center;
        padding: 3rem 1.5rem;
        background:
          radial-gradient(ellipse 70% 50% at 20% 40%, rgba(167, 139, 250, 0.07) 0%, transparent 55%),
          radial-gradient(ellipse 50% 60% at 80% 70%, rgba(34, 211, 238, 0.05) 0%, transparent 50%);
      }

      .land-inner { max-width: 580px; width: 100%; text-align: center; }
      .land-kicker {
        font-size: .55rem;
        letter-spacing: .65em;
        color: var(--dim);
        text-transform: uppercase;
        margin-bottom: 1.8rem;
      }

      .land-title {
        font-family: "Lora", serif;
        font-size: clamp(2.4rem, 7vw, 4.2rem);
        font-weight: 700;
        color: #fff;
        line-height: .95;
        margin-bottom: .8rem;
      }

      .land-sub {
        color: #4a4a62;
        font-size: .88rem;
        line-height: 1.9;
        margin-bottom: 2.5rem;
      }

      .land-sub strong { color: #888; font-weight: 500; }

      .info-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: .5rem;
        margin-bottom: 2.5rem;
      }

      .info-card {
        background: var(--s1);
        border: 1px solid var(--border);
        border-radius: .6rem;
        padding: 1.1rem .8rem;
        text-align: center;
      }

      .info-n {
        font-family: "Lora", serif;
        font-size: 2rem;
        font-weight: 700;
        color: #fff;
        line-height: 1;
      }

      .info-l {
        font-size: .58rem;
        color: var(--dim);
        text-transform: uppercase;
        letter-spacing: .12em;
        margin-top: .2rem;
      }

      .rules-box {
        background: rgba(167, 139, 250, .05);
        border: 1px solid rgba(167, 139, 250, .15);
        border-radius: .5rem;
        padding: .85rem 1.1rem;
        text-align: left;
        font-size: .78rem;
        color: #7070a0;
        line-height: 1.8;
        margin-bottom: 2rem;
      }

      .rules-box li { margin-left: 1rem; margin-bottom: .15rem; }
      .rules-box strong { color: #a0a0c8; font-weight: 600; }
      .rules-box code { color: #ede9fe; font-family: "IBM Plex Mono", monospace; }

      .mode-pills {
        display: flex;
        gap: .5rem;
        justify-content: center;
        margin-bottom: 2rem;
        flex-wrap: wrap;
      }

      .mode-pill {
        display: flex;
        align-items: center;
        gap: .45rem;
        font-size: .7rem;
        font-weight: 600;
        letter-spacing: .06em;
        text-transform: uppercase;
        padding: .4rem .9rem;
        border-radius: 2rem;
        border: 1px solid;
      }

      .mode-pill.infographic {
        color: var(--green);
        border-color: rgba(52, 211, 153, .3);
        background: rgba(52, 211, 153, .06);
      }

      .mode-pill.audio {
        color: var(--teal);
        border-color: rgba(34, 211, 238, .3);
        background: rgba(34, 211, 238, .06);
      }

      #s-exam { flex-direction: column; min-height: 0; }

      #topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: .7rem 2rem;
        background: rgba(6, 6, 12, .97);
        backdrop-filter: blur(16px);
        border-bottom: 1px solid var(--border);
        position: sticky;
        top: 0;
        z-index: 50;
        flex-shrink: 0;
      }

      .tb-left { display: flex; flex-direction: column; }

      .tb-qnum {
        font-family: "Lora", serif;
        font-size: .95rem;
        font-weight: 700;
        color: #fff;
      }

      .tb-qof {
        font-size: .6rem;
        letter-spacing: .2em;
        color: var(--dim);
        text-transform: uppercase;
        margin-top: .1rem;
      }

      .tb-timer {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-family: "IBM Plex Mono", monospace;
        font-size: 1.1rem;
        font-weight: 500;
        color: var(--accent);
      }

      .timer-icon { font-size: .9rem; }

      #progbar-wrap { height: 3px; background: rgba(255, 255, 255, 0.04); flex-shrink: 0; }

      #progbar {
        height: 100%;
        width: 100%;
        background: linear-gradient(90deg, #6d28d9, #22d3ee);
      }

      #qarea {
        display: flex;
        justify-content: center;
        padding: 2rem 1.5rem 3rem;
      }

      .qwrap { max-width: 700px; width: 100%; }

      .media-stack {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
        margin-bottom: 1.4rem;
      }

      .media-card {
        background: rgba(255, 255, 255, .025);
        border: 1px solid rgba(255, 255, 255, .06);
        border-radius: .75rem;
        padding: 1rem;
      }

      .media-label {
        font-size: .58rem;
        font-weight: 700;
        letter-spacing: .15em;
        text-transform: uppercase;
        margin-bottom: .55rem;
        display: flex;
        align-items: center;
        gap: .4rem;
      }

      .media-label.infographic { color: var(--green); }
      .media-label.audio { color: var(--teal); }

      .media-meta {
        font-size: .72rem;
        color: var(--dim);
        margin-bottom: .55rem;
      }

      .media-frame {
        width: 100%;
        height: 500px;
        border: 1px solid rgba(52, 211, 153, .15);
        border-radius: .6rem;
        overflow: hidden;
        display: block;
        background: #e8e4da;
      }

      .media-audio {
        width: 100%;
        height: 36px;
        border-radius: .3rem;
        outline: none;
        accent-color: var(--teal);
      }

      .media-hint {
        font-size: .63rem;
        color: var(--dim);
        margin-top: .4rem;
        font-style: italic;
      }

      .test-content {
        background: var(--s1);
        border: 1px solid rgba(255, 255, 255, .06);
        border-radius: .75rem;
        padding: 1.6rem 1.4rem;
        box-shadow: 0 14px 40px rgba(0, 0, 0, .18);
      }

      .test-content h1,
      .test-content h2,
      .test-content h3 {
        font-family: "Lora", serif;
        color: #f5f5ff;
        line-height: 1.25;
      }

      .test-content h1 { font-size: 1.8rem; margin-bottom: 1rem; }
      .test-content h2 { font-size: 1.2rem; margin-top: 1.8rem; margin-bottom: .7rem; }
      .test-content h3 { font-size: 1rem; margin-top: 1.35rem; margin-bottom: .55rem; }
      .test-content h2:first-child,
      .test-content h3:first-child { margin-top: 0; }

      .test-content p,
      .test-content li {
        color: #c4c4d8;
        line-height: 1.9;
      }

      .test-content p + p { margin-top: .9rem; }

      .test-content ul,
      .test-content ol {
        margin: .6rem 0 1rem 1.2rem;
      }

      .test-content li + li { margin-top: .25rem; }

      .test-content strong { color: #ede9fe; }

      .test-content blockquote {
        background: rgba(255, 255, 255, .025);
        border: 1px solid rgba(255, 255, 255, .06);
        border-left: 3px solid rgba(52, 211, 153, .5);
        border-radius: .45rem;
        padding: .9rem 1rem;
        margin: 1rem 0;
      }

      .test-content hr {
        border: none;
        border-top: 1px solid var(--border);
        margin: 1.6rem 0;
      }

      .test-content code {
        font-family: "IBM Plex Mono", monospace;
        color: #c4b5fd;
        background: rgba(167, 139, 250, .08);
        border: 1px solid rgba(167, 139, 250, .15);
        border-radius: .25rem;
        padding: .08rem .35rem;
      }

      .test-content pre {
        overflow-x: auto;
        background: rgba(255, 255, 255, .025);
        border: 1px solid rgba(255, 255, 255, .06);
        border-radius: .45rem;
        padding: .95rem 1rem;
        margin: 1rem 0;
      }

      .test-content pre code {
        background: transparent;
        border: none;
        padding: 0;
      }

      .test-content table {
        width: 100%;
        border-collapse: collapse;
        margin: 1rem 0;
        font-size: .88rem;
      }

      .test-content th,
      .test-content td {
        border: 1px solid rgba(255, 255, 255, .08);
        padding: .7rem .8rem;
        text-align: left;
      }

      .test-content th {
        color: #fff;
        background: rgba(255, 255, 255, .03);
      }

      .test-content .question-callout {
        background: rgba(34, 211, 238, .04);
        border: 1px solid rgba(34, 211, 238, .12);
        border-radius: .6rem;
        padding: 1rem 1rem;
        margin: 1rem 0 1.2rem;
      }

      .test-content .answer-bank {
        background: rgba(167, 139, 250, .05);
        border: 1px solid rgba(167, 139, 250, .12);
        border-radius: .5rem;
        padding: .9rem 1rem;
        margin: 1rem 0 1.2rem;
      }

      @media (max-width: 540px) {
        #topbar { padding: .6rem 1rem; }
        .tb-timer { font-size: .95rem; }
        .info-grid { grid-template-columns: 1fr; }
        .info-n { font-size: 1.5rem; }
        #qarea { padding: 1.25rem 1rem 2rem; }
        .test-content { padding: 1.2rem 1rem; }
        .media-frame { height: 380px; }
      }
    </style>
  </head>
  <body>
    <section class="screen" id="s-landing">
      <div class="land-inner">
        <p class="land-kicker">{examCode ? `${examCode} · ` : ""}Orange Atlas · Content-First Test</p>
        <h1 class="land-title">{title}</h1>
        <p class="land-sub">{description}</p>

        <div class="mode-pills">
          <div class="mode-pill infographic">{infographicSrc ? "📊 Infografía incluida" : "Markdown Content"}</div>
          <div class="mode-pill audio">{audioSrc ? "🎧 Audio incluido" : "Shared Astro Layout"}</div>
        </div>

        <div class="info-grid">
          <div class="info-card">
            <div class="info-n">{questionCount ?? "MD"}</div>
            <div class="info-l">{questionCount ? "preguntas" : "contenido"}</div>
          </div>
          <div class="info-card">
            <div class="info-n" style="color: var(--warn)">{duration}</div>
            <div class="info-l">minutos</div>
          </div>
          <div class="info-card">
            <div class="info-n">{sourceCount ?? difficulty}</div>
            <div class="info-l">{sourceCount ? "fuentes" : "dificultad"}</div>
          </div>
        </div>

        <div class="rules-box">
          <strong>Cómo usar esta plantilla:</strong>
          <ul>
            <li>Agrega un nuevo archivo Markdown en <code>src/content/tests</code>.</li>
            <li>Completa el frontmatter con título, duración, dificultad y descripción.</li>
            <li>Escribe las preguntas en Markdown y esta plantilla reutilizará la misma estética.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="screen" id="s-exam">
      <div id="topbar">
        <div class="tb-left">
          <div class="tb-qnum">{title}</div>
          <div class="tb-qof">{difficulty} · {duration} minutos</div>
        </div>
        <div class="tb-timer">
          <span class="timer-icon">⏱</span>
          <span>{duration}:00</span>
        </div>
      </div>
      <div id="progbar-wrap"><div id="progbar"></div></div>

      <div id="qarea">
        <article class="qwrap test-content">
          {(infographicSrc || audioSrc) && (
            <div class="media-stack">
              {infographicSrc && (
                <section class="media-card">
                  <div class="media-label infographic">📊 Infografía</div>
                  {infographicTitle && <div class="media-meta">{infographicTitle}</div>}
                  <iframe
                    src={infographicSrc}
                    class="media-frame"
                    frameborder="0"
                    scrolling="yes"
                    title={infographicTitle ?? "Infografía"}
                  ></iframe>
                  <p class="media-hint">Desplaza el infográfico para ver todos los datos.</p>
                </section>
              )}
              {audioSrc && (
                <section class="media-card">
                  <div class="media-label audio">🎧 Audio</div>
                  {audioTitle && <div class="media-meta">{audioTitle}</div>}
                  {audioDescription && <div class="media-meta">{audioDescription}</div>}
                  <audio class="media-audio" controls preload="auto">
                    <source src={audioSrc} type="audio/mpeg" />
                    Tu navegador no soporta el elemento de audio.
                  </audio>
                  <p class="media-hint">Puedes reproducir el audio cuantas veces necesites mientras respondes.</p>
                </section>
              )}
            </div>
          )}
          <slot />
        </article>
      </div>
    </section>
  </body>
</html>
