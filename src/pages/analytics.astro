---
import { getCollection } from "astro:content";
import AuthNav from "../components/AuthNav.astro";
import { DEFAULT_COURSE, inferUnitFromSlug } from "../lib/testMeta";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const iconHref = `${basePath}assets/orangeAtlas.png`;
const tests = await getCollection("tests");
const testMetadata = tests
  .filter((test) => Boolean(test.data.questionsJson))
  .map((test) => {
    const questions = JSON.parse(test.data.questionsJson ?? "[]");
    const sections = Array.from(
      new Set(questions.map((question: { sec?: string }) => question.sec || "Uncategorized")),
    );

    return {
      slug: test.slug,
      title: test.data.title,
      course: test.data.course ?? DEFAULT_COURSE,
      unit: test.data.unit ?? inferUnitFromSlug(test.slug),
      difficulty: test.data.difficulty,
      href: `${basePath}tests/${test.slug}/`,
      questionCount: test.data.questionCount ?? questions.length,
      sections,
    };
  });
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Orange Atlas progress analytics and mastery dashboard." />
    <title>Analytics | Orange Atlas</title>
    <link rel="icon" href={iconHref} type="image/png" />
    <link rel="apple-touch-icon" href={iconHref} />
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Besley:opsz,wght@6..32,600;6..32,800&family=Manrope:wght@400;500;700;800&display=swap");

      :root {
        --bg: #040404;
        --panel: rgba(18, 18, 18, 0.82);
        --panel-strong: rgba(28, 28, 29, 0.94);
        --line: rgba(255, 255, 255, 0.13);
        --text: #fbf7f2;
        --muted: #b9b0a7;
        --subtle: #83796f;
        --orange: #ff7433;
        --gold: #ffbd78;
        --green: #57d68d;
        --red: #ff827c;
        --teal: #45cbbb;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        min-height: 100vh;
        color: var(--text);
        font-family: "Manrope", system-ui, sans-serif;
        background:
          radial-gradient(ellipse 75% 42% at 50% 0%, rgba(255, 116, 51, 0.2), transparent 64%),
          linear-gradient(180deg, #000 0%, var(--bg) 54%, #090909 100%);
        letter-spacing: 0;
      }

      a {
        color: inherit;
      }

      .wrap {
        max-width: 1160px;
        margin: 0 auto;
        padding: 5.5rem 1rem 4rem;
      }

      .topline {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1.6rem;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        text-decoration: none;
        font-weight: 800;
      }

      .brand img {
        width: 2.25rem;
        height: 2.25rem;
        border-radius: 0.5rem;
      }

      .hub-link {
        min-height: 2.35rem;
        display: inline-flex;
        align-items: center;
        border: 1px solid var(--line);
        border-radius: 0.45rem;
        padding: 0 0.8rem;
        color: var(--muted);
        background: rgba(255, 255, 255, 0.04);
        font-size: 0.86rem;
        font-weight: 800;
        text-decoration: none;
      }

      .hero {
        padding: 2.4rem 0 2rem;
      }

      .eyebrow,
      .panel-kicker,
      .stat-label {
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 0.72rem;
        font-weight: 800;
      }

      .eyebrow {
        color: var(--gold);
        margin-bottom: 0.75rem;
      }

      h1,
      h2,
      h3 {
        font-family: "Besley", Georgia, serif;
        letter-spacing: 0;
      }

      h1 {
        max-width: 760px;
        font-size: clamp(2.5rem, 7vw, 5.1rem);
        line-height: 0.98;
        margin-bottom: 1rem;
      }

      .hero-copy {
        max-width: 680px;
        color: var(--muted);
        font-size: 1.04rem;
        line-height: 1.75;
      }

      .status-pill {
        display: inline-flex;
        align-items: center;
        min-height: 2.25rem;
        margin-top: 1.25rem;
        border: 1px solid rgba(255, 189, 120, 0.32);
        border-radius: 999px;
        padding: 0 0.85rem;
        color: var(--gold);
        background: rgba(255, 189, 120, 0.08);
        font-size: 0.82rem;
        font-weight: 800;
      }

      .gate,
      .panel {
        border: 1px solid var(--line);
        border-radius: 0.6rem;
        background: linear-gradient(145deg, var(--panel) 0%, rgba(10, 10, 10, 0.88) 100%);
        box-shadow: 0 20px 54px rgba(0, 0, 0, 0.28);
      }

      .gate {
        display: grid;
        gap: 0.8rem;
        max-width: 640px;
        padding: 1.1rem;
      }

      .gate[hidden],
      .dashboard[hidden] {
        display: none;
      }

      .gate h2 {
        font-size: 1.45rem;
      }

      .gate p {
        color: var(--muted);
        line-height: 1.65;
      }

      .gate button {
        justify-self: start;
        min-height: 2.6rem;
        border: 0;
        border-radius: 0.42rem;
        padding: 0 0.95rem;
        color: #111;
        background: linear-gradient(135deg, var(--orange), var(--gold));
        cursor: pointer;
        font: inherit;
        font-weight: 800;
      }

      .dashboard {
        display: grid;
        gap: 1rem;
      }

      .overview {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.75rem;
      }

      .stat {
        border: 1px solid rgba(255, 116, 51, 0.25);
        border-radius: 0.55rem;
        background: rgba(255, 255, 255, 0.045);
        padding: 0.95rem;
      }

      .stat-value {
        color: var(--gold);
        font-family: "Besley", Georgia, serif;
        font-size: 1.7rem;
        line-height: 1.05;
        word-break: break-word;
      }

      .stat-label {
        margin-top: 0.32rem;
        color: var(--subtle);
      }

      .panel {
        padding: 1rem;
      }

      .panel-head {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: baseline;
        margin-bottom: 0.8rem;
      }

      .panel h2 {
        font-size: 1.25rem;
      }

      .panel-kicker {
        color: var(--subtle);
      }

      .grid-two {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
      }

      .mini-list {
        display: grid;
        gap: 0.55rem;
      }

      .mini-card {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 0.65rem;
        align-items: center;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 0.5rem;
        background: rgba(255, 255, 255, 0.04);
        padding: 0.72rem;
      }

      .mini-title {
        color: var(--text);
        font-weight: 800;
        line-height: 1.35;
      }

      .mini-sub {
        color: var(--muted);
        font-size: 0.84rem;
        line-height: 1.45;
        margin-top: 0.18rem;
      }

      .score-chip {
        min-width: 4.4rem;
        border-radius: 999px;
        padding: 0.28rem 0.55rem;
        text-align: center;
        color: #101010;
        background: var(--gold);
        font-size: 0.82rem;
        font-weight: 900;
      }

      .score-chip.good {
        background: var(--green);
      }

      .score-chip.bad {
        background: var(--red);
      }

      .score-chip.mid {
        background: var(--teal);
      }

      .trend {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(54px, 1fr));
        gap: 0.65rem;
        align-items: end;
        min-height: 180px;
      }

      .bar-wrap {
        display: grid;
        align-items: end;
        gap: 0.45rem;
        min-height: 160px;
      }

      .bar {
        min-height: 0.35rem;
        border-radius: 0.35rem 0.35rem 0.15rem 0.15rem;
        background: linear-gradient(180deg, var(--gold), var(--orange));
      }

      .bar-label {
        color: var(--muted);
        font-size: 0.72rem;
        text-align: center;
        line-height: 1.25;
      }

      .empty {
        color: var(--muted);
        line-height: 1.6;
      }

      @media (max-width: 860px) {
        .overview,
        .grid-two {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 620px) {
        .wrap {
          padding-top: 6.5rem;
        }

        .topline {
          align-items: flex-start;
          flex-direction: column;
        }

        .panel-head,
        .mini-card {
          grid-template-columns: 1fr;
        }

        .score-chip {
          justify-self: start;
        }
      }
    </style>
  </head>
  <body>
    <AuthNav />

    <main class="wrap">
      <div class="topline">
        <a class="brand" href={basePath}>
          <img src={iconHref} alt="" />
          <span>Orange Atlas</span>
        </a>
        <a class="hub-link" href={`${basePath}spanish2/`}>Spanish 2 Hub</a>
      </div>

      <section class="hero">
        <p class="eyebrow">Progress Analytics</p>
        <h1>Know what is mastered and what needs work.</h1>
        <p class="hero-copy">
          Signed-in attempts from the Astro test player become score trends, skill mastery, recent misses, and targeted next-test suggestions.
        </p>
        <p class="status-pill" id="auth-state">Checking sign-in</p>
      </section>

      <section class="gate" id="analytics-gate">
        <h2 id="gate-title">Sign in to view analytics</h2>
        <p id="gate-copy">Use Google sign-in to load saved attempts and progress insights.</p>
        <button type="button" data-auth-action="sign-in" id="gate-signin">Sign in with Google</button>
      </section>

      <section class="dashboard" id="analytics-dashboard" hidden>
        <div class="overview" aria-label="Progress overview">
          <div class="stat">
            <div class="stat-value" id="stat-attempts">0</div>
            <div class="stat-label">Attempts</div>
          </div>
          <div class="stat">
            <div class="stat-value" id="stat-average">0%</div>
            <div class="stat-label">Average score</div>
          </div>
          <div class="stat">
            <div class="stat-value" id="stat-mastered">0</div>
            <div class="stat-label">Mastered areas</div>
          </div>
          <div class="stat">
            <div class="stat-value" id="stat-focus">0</div>
            <div class="stat-label">Focus areas</div>
          </div>
        </div>

        <section class="panel">
          <div class="panel-head">
            <h2>Score Trend</h2>
            <span class="panel-kicker">Recent attempts</span>
          </div>
          <div class="trend" id="score-trend"></div>
        </section>

        <div class="grid-two">
          <section class="panel">
            <div class="panel-head">
              <h2>Mastered</h2>
              <span class="panel-kicker">85%+ with 8+ questions</span>
            </div>
            <div class="mini-list" id="mastered-list"></div>
          </section>

          <section class="panel">
            <div class="panel-head">
              <h2>Needs Work</h2>
              <span class="panel-kicker">Below 70%</span>
            </div>
            <div class="mini-list" id="weak-list"></div>
          </section>
        </div>

        <div class="grid-two">
          <section class="panel">
            <div class="panel-head">
              <h2>Recent Attempts</h2>
              <span class="panel-kicker">Saved history</span>
            </div>
            <div class="mini-list" id="recent-attempts"></div>
          </section>

          <section class="panel">
            <div class="panel-head">
              <h2>Recent Misses</h2>
              <span class="panel-kicker">Question tags</span>
            </div>
            <div class="mini-list" id="recent-misses"></div>
          </section>
        </div>

        <section class="panel">
          <div class="panel-head">
            <h2>Recommended Next Tests</h2>
            <span class="panel-kicker">Based on weak areas</span>
          </div>
          <div class="mini-list" id="recommendations"></div>
        </section>
      </section>
    </main>

    <script type="application/json" id="test-metadata" set:html={JSON.stringify(testMetadata)}></script>
    <script>
      import {
        isFirebaseConfigured,
        loadUserAttempts,
        subscribeToAuth,
      } from "../lib/progress";

      const tests = JSON.parse(document.getElementById("test-metadata")?.textContent || "[]");
      const testsBySlug = new Map(tests.map((test) => [test.slug, test]));
      const gate = document.getElementById("analytics-gate");
      const dashboard = document.getElementById("analytics-dashboard");
      const authState = document.getElementById("auth-state");
      const gateTitle = document.getElementById("gate-title");
      const gateCopy = document.getElementById("gate-copy");
      const gateSignin = document.getElementById("gate-signin");

      const esc = (value) => String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;");

      const pct = (correct, total) => total ? Math.round((correct / total) * 100) : 0;
      const scoreClass = (value) => value >= 85 ? "good" : value < 70 ? "bad" : "mid";

      function attemptMillis(attempt) {
        if (attempt.completedAt && typeof attempt.completedAt.toDate === "function") {
          return attempt.completedAt.toDate().getTime();
        }
        if (attempt.completedAt && typeof attempt.completedAt.seconds === "number") {
          return attempt.completedAt.seconds * 1000;
        }
        if (attempt.completedAtClient) return Date.parse(attempt.completedAtClient);
        return 0;
      }

      function formatDate(attempt) {
        const millis = attemptMillis(attempt);
        if (!millis) return "Saved attempt";
        return new Intl.DateTimeFormat(undefined, { month: "short", day: "numeric" }).format(new Date(millis));
      }

      function sortRecent(attempts) {
        return [...attempts].sort((a, b) => attemptMillis(b) - attemptMillis(a));
      }

      function addBucket(map, key, correct, total) {
        const safeKey = key || "Uncategorized";
        const current = map.get(safeKey) || { key: safeKey, correct: 0, total: 0 };
        current.correct += correct;
        current.total += total;
        map.set(safeKey, current);
      }

      function aggregateSections(attempts) {
        const map = new Map();
        attempts.forEach((attempt) => {
          (attempt.questionResults || []).forEach((question) => {
            addBucket(map, question.section, question.correct ? 1 : 0, 1);
          });
        });
        return [...map.values()]
          .map((item) => ({ ...item, percent: pct(item.correct, item.total) }))
          .sort((a, b) => a.percent === b.percent ? b.total - a.total : b.percent - a.percent);
      }

      function aggregateUnits(attempts) {
        const map = new Map();
        attempts.forEach((attempt) => addBucket(map, attempt.unit, attempt.score || 0, attempt.total || 0));
        return [...map.values()].map((item) => ({ ...item, percent: pct(item.correct, item.total) }));
      }

      function renderList(id, items, emptyText) {
        const el = document.getElementById(id);
        if (!el) return;
        if (!items.length) {
          el.innerHTML = `<p class="empty">${esc(emptyText)}</p>`;
          return;
        }
        el.innerHTML = items.join("");
      }

      function metricCard(title, subtitle, percentValue, extraClass = "") {
        return `<article class="mini-card">
          <div>
            <div class="mini-title">${esc(title)}</div>
            <div class="mini-sub">${esc(subtitle)}</div>
          </div>
          <div class="score-chip ${extraClass || scoreClass(percentValue)}">${percentValue}%</div>
        </article>`;
      }

      function renderTrend(attempts) {
        const el = document.getElementById("score-trend");
        if (!el) return;
        const trend = sortRecent(attempts).reverse().slice(-12);
        if (!trend.length) {
          el.innerHTML = `<p class="empty">Complete a test while signed in to start a score trend.</p>`;
          return;
        }
        el.innerHTML = trend.map((attempt) => {
          const value = Math.max(4, Math.min(100, Number(attempt.percent) || 0));
          return `<div class="bar-wrap" title="${esc(attempt.testTitle)} - ${value}%">
            <div class="bar" style="height:${value}%"></div>
            <div class="bar-label">${value}%<br>${esc(formatDate(attempt))}</div>
          </div>`;
        }).join("");
      }

      function renderRecentAttempts(attempts) {
        const items = sortRecent(attempts).slice(0, 6).map((attempt) => {
          const value = Number(attempt.percent) || 0;
          return `<article class="mini-card">
            <div>
              <div class="mini-title">${esc(attempt.testTitle)}</div>
              <div class="mini-sub">${esc(attempt.unit)} - ${esc(formatDate(attempt))}</div>
            </div>
            <div class="score-chip ${scoreClass(value)}">${value}%</div>
          </article>`;
        });
        renderList("recent-attempts", items, "Saved attempts will appear here.");
      }

      function renderMisses(attempts) {
        const misses = [];
        sortRecent(attempts).forEach((attempt) => {
          (attempt.questionResults || []).forEach((question) => {
            if (!question.correct) {
              misses.push({ attempt, question });
            }
          });
        });

        const items = misses.slice(0, 8).map(({ attempt, question }) => `<article class="mini-card">
          <div>
            <div class="mini-title">${esc(question.section)}</div>
            <div class="mini-sub">${esc(attempt.testTitle)} - Question ${esc(question.id)} - ${esc(question.type)}</div>
          </div>
          <div class="score-chip bad">Review</div>
        </article>`);
        renderList("recent-misses", items, "Missed question tags will appear after saved attempts.");
      }

      function renderRecommendations(attempts, weakSections, weakUnits) {
        const attempted = new Set(attempts.map((attempt) => attempt.testSlug));
        const scored = tests.map((test) => {
          const sectionMatch = test.sections.some((section) => weakSections.includes(section));
          const unitMatch = weakUnits.includes(test.unit);
          const unattempted = !attempted.has(test.slug);
          return {
            ...test,
            rank: (sectionMatch ? 6 : 0) + (unitMatch ? 3 : 0) + (unattempted ? 2 : 0),
            sectionMatch,
            unattempted,
          };
        })
          .filter((test) => test.rank > 0)
          .sort((a, b) => b.rank - a.rank || a.title.localeCompare(b.title))
          .slice(0, 5);

        const fallback = tests
          .filter((test) => !attempted.has(test.slug))
          .slice(0, 5)
          .map((test) => ({ ...test, unattempted: true }));
        const recommendations = scored.length ? scored : fallback;
        const items = recommendations.map((test) => `<a class="mini-card" href="${esc(test.href)}">
          <div>
            <div class="mini-title">${esc(test.title)}</div>
            <div class="mini-sub">${esc(test.unit)} - ${test.questionCount} questions</div>
          </div>
          <div class="score-chip mid">${test.unattempted ? "Start" : "Retry"}</div>
        </a>`);

        renderList("recommendations", items, "All tracked tests have saved attempts. Retry a focus-area test to raise mastery.");
      }

      function renderDashboard(attempts) {
        const attemptsSorted = sortRecent(attempts);
        const totalAttempts = attempts.length;
        const totalScore = attempts.reduce((sum, attempt) => sum + (Number(attempt.score) || 0), 0);
        const totalQuestions = attempts.reduce((sum, attempt) => sum + (Number(attempt.total) || 0), 0);
        const average = pct(totalScore, totalQuestions);
        const sections = aggregateSections(attempts);
        const units = aggregateUnits(attempts);
        const mastered = sections.filter((item) => item.total >= 8 && item.percent >= 85);
        const weak = sections.filter((item) => item.total >= 5 && item.percent < 70).sort((a, b) => a.percent - b.percent);
        const weakUnits = units.filter((unit) => unit.percent < 70).map((unit) => unit.key);

        document.getElementById("stat-attempts").textContent = String(totalAttempts);
        document.getElementById("stat-average").textContent = `${average}%`;
        document.getElementById("stat-mastered").textContent = String(mastered.length);
        document.getElementById("stat-focus").textContent = String(weak.length);

        renderTrend(attemptsSorted);
        renderList(
          "mastered-list",
          mastered.slice(0, 8).map((item) => metricCard(item.key, `${item.correct}/${item.total} correct`, item.percent, "good")),
          "No mastered areas yet. 85%+ across 8 tagged questions will unlock this list.",
        );
        renderList(
          "weak-list",
          weak.slice(0, 8).map((item) => metricCard(item.key, `${item.correct}/${item.total} correct`, item.percent, "bad")),
          "No focus areas yet. More saved attempts will make this sharper.",
        );
        renderRecentAttempts(attemptsSorted);
        renderMisses(attemptsSorted);
        renderRecommendations(attemptsSorted, weak.map((item) => item.key), weakUnits);
      }

      function showGate(title, copy, canSignIn) {
        if (dashboard) dashboard.hidden = true;
        if (gate) gate.hidden = false;
        if (gateTitle) gateTitle.textContent = title;
        if (gateCopy) gateCopy.textContent = copy;
        if (gateSignin) gateSignin.hidden = !canSignIn;
      }

      async function loadAnalytics() {
        if (!isFirebaseConfigured()) {
          if (authState) authState.textContent = "Firebase setup needed";
          showGate("Firebase setup needed", "Add PUBLIC_FIREBASE_* values before Google sign-in and analytics can load.", false);
          return;
        }

        if (authState) authState.textContent = "Loading analytics";
        try {
          const attempts = await loadUserAttempts();
          if (gate) gate.hidden = true;
          if (dashboard) dashboard.hidden = false;
          if (authState) authState.textContent = `${attempts.length} saved attempt${attempts.length === 1 ? "" : "s"}`;
          renderDashboard(attempts);
        } catch (error) {
          console.warn("Unable to load Orange Atlas analytics", error);
          if (authState) authState.textContent = "Analytics failed to load";
          showGate("Analytics failed to load", "Check Firebase configuration and Firestore rules, then try again.", false);
        }
      }

      subscribeToAuth((user) => {
        if (!isFirebaseConfigured()) {
          if (authState) authState.textContent = "Firebase setup needed";
          showGate("Firebase setup needed", "Add PUBLIC_FIREBASE_* values before Google sign-in and analytics can load.", false);
          return;
        }

        if (!user) {
          if (authState) authState.textContent = "Signed out";
          showGate("Sign in to view analytics", "Use Google sign-in to load saved attempts and progress insights.", true);
          return;
        }

        loadAnalytics();
      });
    </script>
  </body>
</html>
