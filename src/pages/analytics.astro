---
import { getCollection } from "astro:content";
import { existsSync, readdirSync, readFileSync } from "node:fs";
import { basename, join, relative } from "node:path";
import AuthNav from "../components/AuthNav.astro";
import { DEFAULT_COURSE, inferUnitFromSlug } from "../lib/testMeta";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const iconHref = `${basePath}assets/orangeAtlas.png`;
const unitOrder: Record<string, number> = {
  "Unidad 4 - En el Consultorio": 4,
  "Unidad 5 - La Tecnologia": 5,
  "Unidad 6 - La Vivienda": 6,
  "Semester 2 Final Review": 7,
};
const getSeriesInfo = (slug: string) => {
  const match = slug.match(/^(.*?)-(\d+)$/);
  return {
    group: match ? match[1] : slug,
    sequence: match ? Number(match[2]) : 0,
  };
};
const getQuestionDetails = (questions: Array<Record<string, any>>) =>
  Object.fromEntries(
    questions.map((question) => [
      String(question.id),
      {
        id: question.id,
        section: question.sec || "Uncategorized",
        type: question.type || "mc",
        prompt: question.prompt || "",
        choices: Array.isArray(question.ch) ? question.ch : [],
        correct: question.cor || "",
        answers: Array.isArray(question.acc) ? question.acc : [],
        display: question.disp || question.cor || (Array.isArray(question.acc) ? question.acc[0] : ""),
        explanation: question.exp || "",
        passage: question.passage || null,
        media: question.media || "",
        englishAnswer: Boolean(question.eng),
      },
    ]),
  );
const legacyRoot = join(process.cwd(), "public", "spanish2");
const legacyFiles: string[] = [];
const walkLegacyFiles = (dir: string) => {
  for (const entry of readdirSync(dir, { withFileTypes: true })) {
    const fullPath = join(dir, entry.name);
    if (entry.isDirectory()) walkLegacyFiles(fullPath);
    else if (entry.isFile() && entry.name.endsWith(".html")) legacyFiles.push(fullPath);
  }
};
if (existsSync(legacyRoot)) walkLegacyFiles(legacyRoot);
const legacyTestMetadata = legacyFiles.map((filePath) => {
  const source = readFileSync(filePath, "utf8");
  const relativePath = relative(join(process.cwd(), "public"), filePath).replaceAll("\\", "/");
  const fileSlug = basename(filePath, ".html")
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");
  const isUnit4 = relativePath.includes("unidad-4-");
  const slug = isUnit4 ? `unidad-4-${fileSlug}` : fileSlug;
  const unit = isUnit4 ? "Unidad 4 - En el Consultorio" : "Unidad 5 - La Tecnologia";
  const titleMatch = source.match(/<title>(.*?)<\/title>/i);
  const h1Match = source.match(/<h1[^>]*>(.*?)<\/h1>/is);
  const sections = Array.from(
    new Set(
      [...source.matchAll(/\b(?:sec|secTitle|title):\s*"([^"]+)"/g)]
        .map((match) => match[1])
        .filter((section) => section.length < 64),
    ),
  );
  const questionCount = (source.match(/\bid:\s*\d+/g) ?? []).length || 20;
  const series = getSeriesInfo(slug);

  return {
    slug,
    title: (titleMatch?.[1] ?? h1Match?.[1] ?? slug).replace(/<[^>]+>/g, "").trim(),
    course: DEFAULT_COURSE,
    unit,
    unitOrder: unitOrder[unit] ?? 99,
    difficulty: "Legacy static test",
    href: `${basePath}${relativePath}`,
    questionCount,
    sections,
    source: "legacy-static",
    ...series,
  };
});
const tests = await getCollection("tests");
const astroTestMetadata = tests
  .filter((test) => Boolean(test.data.questionsJson))
  .map((test) => {
    const questions = JSON.parse(test.data.questionsJson ?? "[]") as Array<Record<string, any>>;
    const sections = Array.from(
      new Set(questions.map((question: { sec?: string }) => question.sec || "Uncategorized")),
    );

    const unit = test.data.unit ?? inferUnitFromSlug(test.slug);
    const series = getSeriesInfo(test.slug);

    return {
      slug: test.slug,
      title: test.data.title,
      course: test.data.course ?? DEFAULT_COURSE,
      unit,
      unitOrder: unitOrder[unit] ?? 99,
      difficulty: test.data.difficulty,
      href: `${basePath}tests/${test.slug}/`,
      questionCount: test.data.questionCount ?? questions.length,
      sections,
      questionDetails: getQuestionDetails(questions),
      source: "astro",
      ...series,
    };
  });
const testMetadata = [...legacyTestMetadata, ...astroTestMetadata].sort(
  (a, b) => a.unitOrder - b.unitOrder || a.group.localeCompare(b.group) || a.sequence - b.sequence,
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Orange Atlas progress analytics and mastery dashboard." />
    <title>Analytics | Orange Atlas</title>
    <link rel="icon" href={iconHref} type="image/png" />
    <link rel="apple-touch-icon" href={iconHref} />
    <style is:global>
      @import url("https://fonts.googleapis.com/css2?family=Besley:opsz,wght@6..32,600;6..32,800&family=IBM+Plex+Mono:wght@400;500&family=Inter:wght@300;400;500;600;700&family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=Manrope:wght@400;500;700;800&display=swap");

      :root {
        --bg: #040404;
        --panel: rgba(18, 18, 18, 0.82);
        --panel-strong: rgba(28, 28, 29, 0.94);
        --line: rgba(255, 255, 255, 0.13);
        --text: #fbf7f2;
        --muted: #b9b0a7;
        --subtle: #83796f;
        --orange: #ff7433;
        --gold: #ffbd78;
        --green: #57d68d;
        --red: #ff827c;
        --teal: #45cbbb;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        min-height: 100vh;
        color: var(--text);
        font-family: "Manrope", system-ui, sans-serif;
        background:
          radial-gradient(ellipse 75% 42% at 50% 0%, rgba(255, 116, 51, 0.2), transparent 64%),
          linear-gradient(180deg, #000 0%, var(--bg) 54%, #090909 100%);
        letter-spacing: 0;
      }

      a {
        color: inherit;
      }

      .wrap {
        max-width: 1160px;
        margin: 0 auto;
        padding: 5.5rem 1rem 4rem;
      }

      .topline {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1.6rem;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        text-decoration: none;
        font-weight: 800;
      }

      .brand img {
        width: 2.25rem;
        height: 2.25rem;
        border-radius: 0.5rem;
      }

      .hub-link {
        min-height: 2.35rem;
        display: inline-flex;
        align-items: center;
        border: 1px solid var(--line);
        border-radius: 0.45rem;
        padding: 0 0.8rem;
        color: var(--muted);
        background: rgba(255, 255, 255, 0.04);
        font-size: 0.86rem;
        font-weight: 800;
        text-decoration: none;
      }

      .hero {
        padding: 2.4rem 0 2rem;
      }

      .hero[hidden] {
        display: none;
      }

      .eyebrow,
      .panel-kicker,
      .stat-label {
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 0.72rem;
        font-weight: 800;
      }

      .eyebrow {
        color: var(--gold);
        margin-bottom: 0.75rem;
      }

      h1,
      h2,
      h3 {
        font-family: "Besley", Georgia, serif;
        letter-spacing: 0;
      }

      h1 {
        max-width: 760px;
        font-size: clamp(2.5rem, 7vw, 5.1rem);
        line-height: 0.98;
        margin-bottom: 1rem;
      }

      .hero-copy {
        max-width: 680px;
        color: var(--muted);
        font-size: 1.04rem;
        line-height: 1.75;
      }

      .status-pill {
        display: inline-flex;
        align-items: center;
        min-height: 2.25rem;
        margin-top: 1.25rem;
        border: 1px solid rgba(255, 189, 120, 0.32);
        border-radius: 999px;
        padding: 0 0.85rem;
        color: var(--gold);
        background: rgba(255, 189, 120, 0.08);
        font-size: 0.82rem;
        font-weight: 800;
      }

      .gate,
      .panel {
        border: 1px solid var(--line);
        border-radius: 0.6rem;
        background: linear-gradient(145deg, var(--panel) 0%, rgba(10, 10, 10, 0.88) 100%);
        box-shadow: 0 20px 54px rgba(0, 0, 0, 0.28);
      }

      .gate {
        display: grid;
        gap: 0.8rem;
        max-width: 640px;
        padding: 1.1rem;
      }

      .gate[hidden],
      .dashboard[hidden] {
        display: none;
      }

      .gate h2 {
        font-size: 1.45rem;
      }

      .gate p {
        color: var(--muted);
        line-height: 1.65;
      }

      .gate button {
        justify-self: start;
        min-height: 2.6rem;
        border: 0;
        border-radius: 0.42rem;
        padding: 0 0.95rem;
        color: #111;
        background: linear-gradient(135deg, var(--orange), var(--gold));
        cursor: pointer;
        font: inherit;
        font-weight: 800;
      }

      .dashboard {
        display: grid;
        gap: 1rem;
      }

      .overview {
        display: grid;
        grid-template-columns: 1.25fr repeat(3, minmax(0, 1fr));
        gap: 0.75rem;
      }

      .stat {
        border: 1px solid rgba(255, 116, 51, 0.25);
        border-radius: 0.55rem;
        background: rgba(255, 255, 255, 0.045);
        padding: 0.95rem;
      }

      .stat.average-card {
        background: linear-gradient(145deg, rgba(255, 116, 51, 0.2), rgba(255, 255, 255, 0.05));
        border-color: rgba(255, 116, 51, 0.42);
      }

      .stat-value {
        color: var(--gold);
        font-family: "Besley", Georgia, serif;
        font-size: 1.7rem;
        line-height: 1.05;
        word-break: break-word;
      }

      .stat-label {
        margin-top: 0.32rem;
        color: var(--subtle);
      }

      .panel {
        padding: 1rem;
      }

      .panel-head {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: baseline;
        margin-bottom: 0.8rem;
      }

      .panel h2 {
        font-size: 1.25rem;
      }

      .panel-kicker {
        color: var(--subtle);
      }

      .grid-two {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
      }

      .mini-list {
        display: grid;
        gap: 0.55rem;
      }

      .test-grid,
      .practice-list {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
        gap: 0.75rem;
      }

      .mini-card {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 0.65rem;
        align-items: center;
        min-height: 6.2rem;
        border: 1px solid rgba(255, 116, 51, 0.22);
        border-radius: 0.5rem;
        background: rgba(255, 255, 255, 0.04);
        padding: 0.9rem;
        color: inherit;
        text-decoration: none;
        transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease;
      }

      a.mini-card:hover {
        transform: translateY(-2px);
        border-color: rgba(255, 116, 51, 0.62);
        background: rgba(255, 116, 51, 0.09);
      }

      .miss-card {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 0.65rem;
        align-items: center;
        width: 100%;
        min-height: 6.2rem;
        border: 1px solid rgba(255, 116, 51, 0.22);
        border-radius: 0.5rem;
        background: rgba(255, 255, 255, 0.04);
        padding: 0.9rem;
        color: inherit;
        cursor: pointer;
        font: inherit;
        text-align: left;
        transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease;
      }

      .miss-card:hover,
      .miss-card:focus-visible {
        transform: translateY(-2px);
        border-color: rgba(255, 116, 51, 0.62);
        background: rgba(255, 116, 51, 0.09);
        outline: none;
      }

      .miss-card.is-cleared {
        display: none;
      }

      .mini-title {
        color: var(--text);
        font-weight: 800;
        line-height: 1.35;
      }

      .mini-sub {
        color: var(--muted);
        font-size: 0.84rem;
        line-height: 1.45;
        margin-top: 0.18rem;
      }

      .miss-question {
        color: var(--muted);
        font-size: 0.84rem;
        line-height: 1.5;
        margin-top: 0.3rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .miss-open,
      .miss-link {
        min-height: 2.2rem;
        border-radius: 0.38rem;
        padding: 0 0.78rem;
        font-size: 0.72rem;
        font-weight: 900;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-decoration: none;
      }

      .miss-open,
      .miss-link {
        display: inline-flex;
        align-items: center;
        border: 1px solid rgba(255, 116, 51, 0.28);
        color: var(--gold);
        background: rgba(255, 116, 51, 0.08);
      }

      .miss-card:hover .miss-open,
      .miss-card:focus-visible .miss-open {
        background: linear-gradient(135deg, var(--orange), var(--gold));
        color: #111;
        border-color: transparent;
      }

      .miss-review {
        position: fixed;
        inset: 0;
        z-index: 90;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        background: #06060c;
        color: #ccccd8;
        font-family: "Inter", "Manrope", system-ui, sans-serif;
      }

      .miss-review[hidden] {
        display: none;
      }

      body.miss-review-open {
        overflow: hidden;
      }

      .miss-review .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 0.7rem 2rem;
        background: rgba(6, 6, 12, 0.97);
        backdrop-filter: blur(16px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.07);
        position: sticky;
        top: 0;
        z-index: 2;
        flex-shrink: 0;
      }

      .miss-review .tb-left {
        display: flex;
        flex-direction: column;
      }

      .miss-review .tb-qnum {
        font-family: "Lora", Georgia, serif;
        font-size: 0.95rem;
        font-weight: 700;
        color: #fff;
      }

      .miss-review .tb-qof {
        color: #3e3e52;
        font-size: 0.6rem;
        letter-spacing: 0.2em;
        margin-top: 0.1rem;
        text-transform: uppercase;
      }

      .miss-review .review-return {
        min-height: 2.35rem;
        border: 1px solid rgba(167, 139, 250, 0.28);
        border-radius: 0.38rem;
        padding: 0 0.85rem;
        color: #c4b5fd;
        background: rgba(167, 139, 250, 0.08);
        cursor: pointer;
        font: inherit;
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .miss-review .progbar-wrap {
        height: 3px;
        background: rgba(255, 255, 255, 0.04);
        flex-shrink: 0;
      }

      .miss-review .progbar {
        height: 100%;
        width: 100%;
        background: linear-gradient(90deg, #6d28d9, #a78bfa);
      }

      .miss-review .qarea {
        flex: 1;
        display: flex;
        align-items: flex-start;
        justify-content: center;
        overflow: auto;
        padding: 2rem 1.5rem 3rem;
      }

      .miss-review .qwrap {
        width: 100%;
        max-width: 700px;
        animation: qfade 0.35s ease;
      }

      .miss-review .qsec-label {
        color: #3e3e52;
        font-size: 0.62rem;
        letter-spacing: 0.2em;
        margin-bottom: 0.4rem;
        text-transform: uppercase;
      }

      .miss-review .qtype-badge {
        display: inline-block;
        border-radius: 0.2rem;
        margin-bottom: 0.9rem;
        padding: 0.12rem 0.5rem;
        font-size: 0.58rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .miss-review .passage-card {
        background: #0f0f18;
        border: 1px solid rgba(52, 211, 153, 0.12);
        border-radius: 0.75rem;
        box-shadow: 0 14px 40px rgba(0, 0, 0, 0.18);
        color: #b6b6c8;
        line-height: 1.9;
        margin-bottom: 1.4rem;
        padding: 1.2rem 1.4rem;
      }

      .miss-review .passage-label {
        color: #34d399;
        font: 700 0.58rem "Inter", sans-serif;
        letter-spacing: 0.15em;
        margin-bottom: 0.55rem;
        text-transform: uppercase;
      }

      .miss-review .passage-body {
        color: #c4c4d8;
        font-family: "Lora", Georgia, serif;
        font-size: 0.96rem;
        line-height: 1.95;
      }

      .miss-review .qprompt {
        color: #ddd;
        font-family: "Lora", Georgia, serif;
        font-size: clamp(1rem, 2.5vw, 1.15rem);
        line-height: 1.85;
        margin-bottom: 1.4rem;
        white-space: pre-line;
      }

      .miss-review .choices-grid {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-bottom: 1.4rem;
      }

      .miss-review .choice-btn {
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 0.45rem;
        background: rgba(255, 255, 255, 0.025);
        color: #888;
        cursor: pointer;
        font: 0.88rem/1.5 "Inter", sans-serif;
        padding: 0.75rem 1rem;
        text-align: left;
        transition: all 0.13s;
      }

      .miss-review .choice-btn:hover {
        background: rgba(255, 255, 255, 0.055);
        border-color: rgba(255, 255, 255, 0.14);
        color: #ccc;
      }

      .miss-review .choice-btn.sel {
        border-color: rgba(167, 139, 250, 0.55);
        color: #ede9fe;
        background: rgba(167, 139, 250, 0.08);
      }

      .miss-review .choice-btn.correct {
        border-color: rgba(52, 211, 153, 0.35);
        color: #86efac;
        background: rgba(52, 211, 153, 0.08);
      }

      .miss-review .choice-btn.wrong {
        border-color: rgba(248, 113, 113, 0.35);
        color: #fca5a5;
        background: rgba(248, 113, 113, 0.08);
      }

      .miss-review .free-wrap {
        margin-bottom: 1.4rem;
      }

      .miss-review .free-label {
        color: #3e3e52;
        font-size: 0.65rem;
        letter-spacing: 0.15em;
        margin-bottom: 0.5rem;
        text-transform: uppercase;
      }

      .miss-review .free-input {
        width: 100%;
        border: 1.5px solid rgba(255, 255, 255, 0.09);
        border-radius: 0.45rem;
        background: rgba(255, 255, 255, 0.03);
        color: #ccccd8;
        font: 1rem "IBM Plex Mono", monospace;
        letter-spacing: 0.04em;
        outline: none;
        padding: 0.8rem 1rem;
        transition: border-color 0.2s, background 0.2s;
      }

      .miss-review .free-input:focus {
        border-color: rgba(167, 139, 250, 0.35);
        background: rgba(167, 139, 250, 0.04);
      }

      .miss-review .accent-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-top: 0.6rem;
      }

      .miss-review .accent-btn {
        min-width: 2rem;
        border: 1px solid rgba(167, 139, 250, 0.3);
        border-radius: 0.35rem;
        background: rgba(167, 139, 250, 0.12);
        color: #a78bfa;
        cursor: pointer;
        font: 600 0.85rem "Inter", sans-serif;
        padding: 0.4rem 0.6rem;
        text-align: center;
        transition: all 0.15s;
      }

      .miss-review .accent-btn:hover {
        background: rgba(167, 139, 250, 0.22);
        border-color: rgba(167, 139, 250, 0.5);
        color: #c4b5fd;
      }

      .miss-review .btn-next {
        width: 100%;
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 0.4rem;
        background: #15151f;
        color: #444;
        cursor: not-allowed;
        font: 600 0.85rem "Inter", sans-serif;
        letter-spacing: 0.08em;
        padding: 0.85rem 2.5rem;
        text-transform: uppercase;
        transition: all 0.2s;
      }

      .miss-review .btn-next.ready {
        border-color: transparent;
        background: linear-gradient(135deg, #6d28d9, #4f46e5);
        box-shadow: 0 0 30px rgba(109, 40, 217, 0.3);
        color: #fff;
        cursor: pointer;
      }

      .miss-review .btn-next.ready:hover {
        box-shadow: 0 0 50px rgba(109, 40, 217, 0.45);
        transform: translateY(-1px);
      }

      .miss-review .miss-review-feedback {
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 0.5rem;
        background: rgba(255, 255, 255, 0.035);
        color: #888;
        line-height: 1.75;
        margin-top: 1rem;
        padding: 0.85rem 1rem;
      }

      .miss-review .miss-review-feedback.good {
        border-color: rgba(52, 211, 153, 0.24);
        color: #86efac;
      }

      .miss-review .miss-review-feedback.bad {
        border-color: rgba(248, 113, 113, 0.24);
        color: #fca5a5;
      }

      @keyframes qfade {
        from {
          opacity: 0;
          transform: translateY(12px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .score-chip {
        min-width: 4.4rem;
        border-radius: 999px;
        padding: 0.28rem 0.55rem;
        text-align: center;
        color: #101010;
        background: var(--gold);
        font-size: 0.82rem;
        font-weight: 900;
      }

      .score-chip.good {
        background: var(--green);
      }

      .score-chip.bad {
        background: var(--red);
      }

      .score-chip.mid {
        background: var(--teal);
      }

      .trend {
        min-height: 260px;
      }

      .chart-wrap {
        position: relative;
        min-height: 260px;
        border: 1px solid rgba(255, 255, 255, 0.09);
        border-radius: 0.55rem;
        background: #000;
        padding: 0.75rem;
        overflow: hidden;
        box-shadow:
          inset 0 0 0 1px rgba(255, 255, 255, 0.03),
          inset 0 -34px 90px rgba(255, 116, 51, 0.08);
      }

      .line-chart {
        display: block;
        width: 100%;
        height: 240px;
        overflow: visible;
      }

      .chart-line {
        fill: none;
        stroke: #ff9a4a;
        stroke-width: 2.35;
        stroke-linecap: round;
        stroke-linejoin: round;
        filter: drop-shadow(0 0 5px rgba(255, 116, 51, 0.42));
      }

      .chart-line-glow {
        fill: none;
        stroke: #ff7433;
        stroke-width: 7;
        stroke-linecap: round;
        stroke-linejoin: round;
        opacity: 0.18;
        filter: blur(5px);
      }

      .chart-area-group {
        filter: drop-shadow(0 -3px 12px rgba(255, 116, 51, 0.18));
      }

      .chart-area-slice {
        opacity: 0.95;
      }

      .chart-grid-line {
        stroke: rgba(255, 255, 255, 0.12);
        stroke-width: 1;
        vector-effect: non-scaling-stroke;
      }

      .chart-dot {
        fill: var(--gold);
        stroke: #0b0b0b;
        stroke-width: 3.5;
      }

      .chart-dot.origin {
        fill: #0b0b0b;
        stroke: var(--orange);
      }

      .chart-label,
      .chart-axis {
        fill: var(--muted);
        font-size: 12px;
        font-weight: 800;
      }

      .chart-axis {
        fill: var(--subtle);
      }

      .test-card,
      .practice-card {
        min-height: 9.4rem;
        display: flex;
        flex-direction: column;
        gap: 0.45rem;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 0.5rem;
        background: rgba(255, 255, 255, 0.04);
        color: inherit;
        padding: 0.92rem;
        text-decoration: none;
        transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease;
      }

      .test-card.live,
      .practice-card {
        border: 1px solid rgba(255, 116, 51, 0.24);
      }

      .test-card.live:hover,
      .test-card.live:focus-visible,
      .practice-card:hover,
      .practice-card:focus-visible {
        transform: translateY(-2px);
        border-color: rgba(255, 116, 51, 0.62);
        background: rgba(255, 116, 51, 0.09);
        outline: none;
      }

      .practice-kicker {
        color: var(--gold);
        font-size: 0.68rem;
        font-weight: 900;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .test-name,
      .practice-title {
        color: var(--text);
        font-family: "Besley", Georgia, serif;
        font-size: 1.03rem;
        line-height: 1.16;
        letter-spacing: 0;
      }

      .test-note,
      .practice-note {
        flex: 1;
        color: var(--muted);
        font-size: 0.86rem;
        line-height: 1.55;
      }

      .open,
      .practice-open {
        color: var(--gold);
        font-size: 0.88rem;
        font-weight: 700;
      }

      .empty {
        color: var(--muted);
        line-height: 1.6;
      }

      @media (max-width: 860px) {
        .overview,
        .grid-two {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 620px) {
        .wrap {
          padding-top: 6.5rem;
        }

        .topline {
          align-items: flex-start;
          flex-direction: column;
        }

        .panel-head,
        .mini-card {
          grid-template-columns: 1fr;
        }

        .miss-card {
          grid-template-columns: 1fr;
        }

        .score-chip {
          justify-self: start;
        }

        .miss-review .topbar {
          align-items: flex-start;
          flex-direction: column;
          padding: 0.7rem 1rem;
        }
      }
    </style>
  </head>
  <body>
    <AuthNav />

    <main class="wrap">
      <div class="topline">
        <a class="brand" href={basePath}>
          <img src={iconHref} alt="" />
          <span>Orange Atlas</span>
        </a>
        <a class="hub-link" href={`${basePath}spanish2/`}>Spanish 2 Hub</a>
      </div>

      <section class="hero">
        <p class="eyebrow">Progress Analytics</p>
        <h1>Know what is mastered and what needs work.</h1>
        <p class="hero-copy">
          Signed-in attempts from all supported Spanish 2 tests become score trends, skill mastery, recent misses, and targeted next-test suggestions.
        </p>
        <p class="status-pill" id="auth-state">Checking sign-in</p>
      </section>

      <section class="gate" id="analytics-gate">
        <h2 id="gate-title">Sign in to view analytics</h2>
        <p id="gate-copy">Use Google sign-in to load saved attempts and progress insights.</p>
        <button type="button" data-auth-action="sign-in" id="gate-signin">Sign in with Google</button>
      </section>

      <section class="dashboard" id="analytics-dashboard" hidden>
        <div class="overview" aria-label="Progress overview">
          <div class="stat average-card">
            <div class="stat-value" id="stat-average">0%</div>
            <div class="stat-label">Average score</div>
          </div>
          <div class="stat">
            <div class="stat-value" id="stat-attempts">0</div>
            <div class="stat-label">Attempts</div>
          </div>
          <div class="stat">
            <div class="stat-value" id="stat-mastered">0</div>
            <div class="stat-label">Mastered areas</div>
          </div>
          <div class="stat">
            <div class="stat-value" id="stat-focus">0</div>
            <div class="stat-label">Focus areas</div>
          </div>
        </div>

        <section class="panel">
          <div class="panel-head">
            <h2>Score Trend</h2>
            <span class="panel-kicker">Charted over time</span>
          </div>
          <div class="trend" id="score-trend"></div>
        </section>

        <div class="grid-two">
          <section class="panel">
            <div class="panel-head">
              <h2>Unit Performance</h2>
              <span class="panel-kicker">Course map</span>
            </div>
            <div class="mini-list" id="unit-list"></div>
          </section>

          <section class="panel">
            <div class="panel-head">
              <h2>Format Breakdown</h2>
              <span class="panel-kicker">Question types</span>
            </div>
            <div class="mini-list" id="type-list"></div>
          </section>
        </div>

        <section class="panel">
          <div class="panel-head">
            <h2>Source Breakdown</h2>
            <span class="panel-kicker">Text, media, and standard questions</span>
          </div>
          <div class="mini-list" id="media-list"></div>
        </section>

        <div class="grid-two">
          <section class="panel">
            <div class="panel-head">
              <h2>Mastered</h2>
              <span class="panel-kicker">85%+ with 8+ questions</span>
            </div>
            <div class="mini-list" id="mastered-list"></div>
          </section>

          <section class="panel">
            <div class="panel-head">
              <h2>Needs Work</h2>
              <span class="panel-kicker">Below 70%</span>
            </div>
            <div class="mini-list" id="weak-list"></div>
          </section>
        </div>

        <div class="grid-two">
          <section class="panel">
            <div class="panel-head">
              <h2>Recent Attempts</h2>
              <span class="panel-kicker">Saved history</span>
            </div>
            <div class="mini-list" id="recent-attempts"></div>
          </section>

          <section class="panel">
            <div class="panel-head">
              <h2>Recent Misses</h2>
              <span class="panel-kicker">Question tags</span>
            </div>
            <div class="mini-list" id="recent-misses"></div>
          </section>
        </div>

        <section class="panel">
          <div class="panel-head">
            <h2>Recommended Next Tests</h2>
            <span class="panel-kicker">Based on weak areas</span>
          </div>
          <div class="test-grid practice-list" id="recommendations"></div>
        </section>
      </section>
    </main>

    <section class="miss-review" id="miss-review" hidden aria-live="polite">
      <div class="topbar">
        <div class="tb-left">
          <div class="tb-qnum" id="miss-review-title">Question Review</div>
          <div class="tb-qof" id="miss-review-meta">Pregunta 1 de 1</div>
        </div>
        <button class="review-return" type="button" data-miss-return>Return</button>
      </div>
      <div class="progbar-wrap"><div class="progbar"></div></div>
      <div class="qarea">
        <div class="qwrap" id="miss-review-body"></div>
      </div>
    </section>

    <script type="application/json" id="test-metadata" set:html={JSON.stringify(testMetadata)}></script>
    <script>
      import {
        isFirebaseConfigured,
        loadUserAttempts,
        subscribeToAuth,
      } from "../lib/progress";

      const tests = JSON.parse(document.getElementById("test-metadata")?.textContent || "[]");
      const testsBySlug = new Map(tests.map((test) => [test.slug, test]));
      const unitOrder = ["Unidad 4 - En el Consultorio", "Unidad 5 - La Tecnologia", "Unidad 6 - La Vivienda", "Semester 2 Final Review"];
      const gate = document.getElementById("analytics-gate");
      const dashboard = document.getElementById("analytics-dashboard");
      const hero = document.querySelector(".hero");
      const authState = document.getElementById("auth-state");
      const gateTitle = document.getElementById("gate-title");
      const gateCopy = document.getElementById("gate-copy");
      const gateSignin = document.getElementById("gate-signin");
      const missReview = document.getElementById("miss-review");
      const missReviewBody = document.getElementById("miss-review-body");
      const missReviewTitle = document.getElementById("miss-review-title");
      const missReviewMeta = document.getElementById("miss-review-meta");

      const esc = (value) => String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;");

      const escAttr = (value) => esc(value).replace(/'/g, "&#39;");
      const pct = (correct, total) => total ? Math.round((correct / total) * 100) : 0;
      const scoreClass = (value) => value >= 85 ? "good" : value < 70 ? "bad" : "mid";
      let activeUserId = "local";
      let clearedMisses = new Set();
      let reviewMisses = [];
      let activeReview = null;
      let activeReviewAnswer = "";

      const mediaLabelMap = {
        "": "Standard questions",
        none: "Standard questions",
        standard: "Standard questions",
        "standard questions": "Standard questions",
        infographic: "Infographic",
        audio: "Audio",
        passage: "Text passage",
        text: "Text passage",
      };

      function normalizeMediaLabel(value) {
        const key = String(value ?? "").trim().toLowerCase();
        return mediaLabelMap[key] || String(value || "Standard questions");
      }

      function missStorageKey() {
        return `orangeAtlasClearedMisses:v1:${activeUserId || "local"}`;
      }

      function loadClearedMisses(userId) {
        activeUserId = userId || "local";
        try {
          clearedMisses = new Set(JSON.parse(localStorage.getItem(missStorageKey()) || "[]"));
        } catch {
          clearedMisses = new Set();
        }
      }

      function saveClearedMisses() {
        localStorage.setItem(missStorageKey(), JSON.stringify([...clearedMisses]));
      }

      function normalizeAnswer(value) {
        return String(value ?? "")
          .normalize("NFD")
          .replace(/[\u0300-\u036f]/g, "")
          .toLowerCase()
          .trim()
          .replace(/\s+/g, " ")
          .replace(/[.,!?;:'"()]/g, "");
      }

      function missKey(attempt, question) {
        return [
          attempt.id || attempt.completedAtClient || attemptMillis(attempt) || attempt.testSlug,
          attempt.testSlug,
          question.id,
        ].join(":");
      }

      function attemptMillis(attempt) {
        if (attempt.completedAt && typeof attempt.completedAt.toDate === "function") {
          return attempt.completedAt.toDate().getTime();
        }
        if (attempt.completedAt && typeof attempt.completedAt.seconds === "number") {
          return attempt.completedAt.seconds * 1000;
        }
        if (attempt.completedAtClient) return Date.parse(attempt.completedAtClient);
        return 0;
      }

      function formatDate(attempt) {
        const millis = attemptMillis(attempt);
        if (!millis) return "Saved attempt";
        return new Intl.DateTimeFormat(undefined, { month: "short", day: "numeric" }).format(new Date(millis));
      }

      function sortRecent(attempts) {
        return [...attempts].sort((a, b) => attemptMillis(b) - attemptMillis(a));
      }

      function addBucket(map, key, correct, total) {
        const safeKey = key || "Uncategorized";
        const current = map.get(safeKey) || { key: safeKey, correct: 0, total: 0 };
        current.correct += correct;
        current.total += total;
        map.set(safeKey, current);
      }

      function aggregateSections(attempts) {
        const map = new Map();
        attempts.forEach((attempt) => {
          (attempt.questionResults || []).forEach((question) => {
            addBucket(map, question.section, question.correct ? 1 : 0, 1);
          });
        });
        return [...map.values()]
          .map((item) => ({ ...item, percent: pct(item.correct, item.total) }))
          .sort((a, b) => a.percent === b.percent ? b.total - a.total : b.percent - a.percent);
      }

      function aggregateUnits(attempts) {
        const map = new Map();
        attempts.forEach((attempt) => addBucket(map, attempt.unit, attempt.score || 0, attempt.total || 0));
        return [...map.values()].map((item) => ({ ...item, percent: pct(item.correct, item.total) }));
      }

      function aggregateObjectStats(attempts, key) {
        const map = new Map();
        attempts.forEach((attempt) => {
          const stats = attempt[key] || {};
          Object.entries(stats).forEach(([name, stat]) => {
            const statName = key === "mediaStats" ? normalizeMediaLabel(name) : name;
            addBucket(map, statName, Number(stat.correct) || 0, Number(stat.total) || 0);
          });
        });
        return [...map.values()]
          .map((item) => ({ ...item, percent: pct(item.correct, item.total) }))
          .sort((a, b) => a.percent === b.percent ? b.total - a.total : b.percent - a.percent);
      }

      function renderList(id, items, emptyText) {
        const el = document.getElementById(id);
        if (!el) return;
        if (!items.length) {
          el.innerHTML = `<p class="empty">${esc(emptyText)}</p>`;
          return;
        }
        el.innerHTML = items.join("");
      }

      function metricCard(title, subtitle, percentValue, extraClass = "") {
        return `<article class="mini-card">
          <div>
            <div class="mini-title">${esc(title)}</div>
            <div class="mini-sub">${esc(subtitle)}</div>
          </div>
          <div class="score-chip ${extraClass || scoreClass(percentValue)}">${percentValue}%</div>
        </article>`;
      }

      function withReviewParam(href, questionId) {
        if (!href) return "#";
        const joiner = href.includes("?") ? "&" : "?";
        return `${href}${joiner}review=${encodeURIComponent(questionId)}`;
      }

      function testCard(test, chip, subtitle = "") {
        return `<a class="test-card live practice-card" href="${esc(test.href)}" aria-label="Open ${esc(test.title)}">
          <p class="practice-kicker">${esc(chip)} Practice</p>
          <h3 class="test-name practice-title">${esc(test.title)}</h3>
          <p class="test-note practice-note">${esc(subtitle || `${test.unit} - ${test.questionCount} questions`)}</p>
          <p class="open practice-open">Start Test -></p>
        </a>`;
      }

      function renderTrend(attempts) {
        const el = document.getElementById("score-trend");
        if (!el) return;
        const trend = sortRecent(attempts).reverse().slice(-12);
        const width = 760;
        const height = 240;
        const padX = 44;
        const padTop = 18;
        const padBottom = 42;
        const plotW = width - padX * 2;
        const plotH = height - padTop - padBottom;
        const baseY = height - padBottom;
        const points = [
          {
            attempt: null,
            value: 0,
            x: padX,
            y: baseY,
            label: "0",
            title: "Time 0 - 0%",
            isOrigin: true,
          },
          ...trend.map((attempt, index) => {
            const x = padX + ((index + 1) / trend.length) * plotW;
            const value = Math.max(0, Math.min(100, Number(attempt.percent) || 0));
            const y = padTop + (1 - value / 100) * plotH;
            return {
              attempt,
              value,
              x,
              y,
              label: formatDate(attempt),
              title: `${attempt.testTitle} - ${value}%`,
              isOrigin: false,
            };
          }),
        ];
        const linePath = points.map((point, index) => `${index === 0 ? "M" : "L"} ${point.x.toFixed(1)} ${point.y.toFixed(1)}`).join(" ");
        const areaGradients = [];
        const areaSlices = [];
        points.slice(1).forEach((point, segmentIndex) => {
          const previous = points[segmentIndex];
          const steps = Math.max(4, Math.ceil(Math.abs(point.x - previous.x) / 18));
          for (let step = 0; step < steps; step++) {
            const t0 = step / steps;
            const t1 = (step + 1) / steps;
            const x0 = previous.x + (point.x - previous.x) * t0;
            const x1 = previous.x + (point.x - previous.x) * t1;
            const y0 = previous.y + (point.y - previous.y) * t0;
            const y1 = previous.y + (point.y - previous.y) * t1;
            const gradientTop = Math.max(padTop, (y0 + y1) / 2);
            const gradientId = `scoreAreaGradient-${segmentIndex}-${step}`;
            areaGradients.push(`<linearGradient id="${gradientId}" x1="0" y1="${gradientTop.toFixed(1)}" x2="0" y2="${baseY}" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#ff7433" stop-opacity="0.58" />
              <stop offset="16%" stop-color="#ff7433" stop-opacity="0.22" />
              <stop offset="36%" stop-color="#ff7433" stop-opacity="0.06" />
              <stop offset="100%" stop-color="#000000" stop-opacity="0" />
            </linearGradient>`);
            areaSlices.push(`<path class="chart-area-slice" d="M ${x0.toFixed(1)} ${y0.toFixed(1)} L ${x1.toFixed(1)} ${y1.toFixed(1)} L ${x1.toFixed(1)} ${baseY} L ${x0.toFixed(1)} ${baseY} Z" fill="url(#${gradientId})" />`);
          }
        });
        const gridLines = [0, 25, 50, 75, 100].map((value) => {
          const y = padTop + (1 - value / 100) * plotH;
          return `<line class="chart-grid-line" x1="${padX}" y1="${y.toFixed(1)}" x2="${width - padX}" y2="${y.toFixed(1)}" />`;
        }).join("");
        const labels = points.map((point, index) => {
          const showLabel = points.length <= 7 || index === 0 || index === points.length - 1 || index % 2 === 0;
          return `${showLabel ? `<text class="chart-label" x="${point.x}" y="${height - 13}" text-anchor="middle">${esc(point.label)}</text>` : ""}
            <circle class="chart-dot${point.isOrigin ? " origin" : ""}" cx="${point.x}" cy="${point.y}" r="${point.isOrigin ? 4.5 : 5.5}">
              <title>${esc(point.title)}</title>
            </circle>
            <text class="chart-label" x="${point.x}" y="${Math.max(14, point.y - 10)}" text-anchor="middle">${point.value}%</text>`;
        }).join("");
        el.innerHTML = `<div class="chart-wrap">
          <svg class="line-chart" viewBox="0 0 ${width} ${height}" role="img" aria-label="Score trend chart">
            <defs>
              ${areaGradients.join("")}
            </defs>
            ${gridLines}
            <text class="chart-axis" x="6" y="${padTop + 5}">100%</text>
            <text class="chart-axis" x="13" y="${height - padBottom}">0%</text>
            <g class="chart-area-group">${areaSlices.join("")}</g>
            <path class="chart-line-glow" d="${linePath}" />
            <path class="chart-line" d="${linePath}" />
            ${labels}
          </svg>
        </div>`;
      }

      function renderRecentAttempts(attempts) {
        const items = sortRecent(attempts).slice(0, 6).map((attempt) => {
          const value = Number(attempt.percent) || 0;
          return `<article class="mini-card">
            <div>
              <div class="mini-title">${esc(attempt.testTitle)}</div>
              <div class="mini-sub">${esc(attempt.unit)} - ${esc(formatDate(attempt))}</div>
            </div>
            <div class="score-chip ${scoreClass(value)}">${value}%</div>
          </article>`;
        });
        renderList("recent-attempts", items, "Saved attempts will appear here.");
      }

      function getQuestionDetail(attempt, question) {
        const test = testsBySlug.get(attempt.testSlug);
        return test?.questionDetails?.[String(question.id)] || null;
      }

      function answerDisplay(detail) {
        if (!detail) return "";
        if (detail.type === "mc") {
          return detail.choices.find((choice) => String(choice).startsWith(`${detail.correct})`)) || detail.correct;
        }
        return detail.display || detail.answers?.[0] || "";
      }

      function passageHtml(passage) {
        if (!passage) return "";
        const body = typeof passage === "string" ? passage : passage.body || passage.text || "";
        const title = typeof passage === "object" && passage.title ? passage.title : "Reading passage";
        if (!body) return "";
        return `<div class="passage-card">
          <div class="passage-label">${esc(title)}</div>
          <div class="passage-body">${esc(body)}</div>
        </div>`;
      }

      function reviewQuestionHtml(review) {
        const detail = review.detail;
        const typeColor = detail.type === "mc" ? "#a78bfa" : "#34d399";
        const typeLabel = detail.type === "mc" ? "Opción Múltiple" : "Respuesta Libre";
        let html = `<div class="qsec-label">${esc(detail.section || review.question.section || "Uncategorized")}</div>
          <span class="qtype-badge" style="background:${typeColor}18;color:${typeColor}">${typeLabel}</span>
          ${passageHtml(detail.passage)}
          <p class="qprompt">${esc(detail.prompt)}</p>`;

        if (detail.type === "mc" && detail.choices?.length) {
          html += `<div class="choices-grid">`;
          detail.choices.forEach((choice) => {
            const value = String(choice).slice(0, 1);
            html += `<button class="choice-btn" type="button" data-review-choice="${escAttr(value)}">${esc(choice)}</button>`;
          });
          html += `</div>`;
        } else {
          const labelText = detail.englishAnswer ? "Write a short English phrase" : "Escribe tu respuesta";
          const placeholderText = detail.englishAnswer ? "short English phrase..." : "tu respuesta...";
          html += `<div class="free-wrap">
            <div class="free-label">${labelText}</div>
            <input class="free-input" id="miss-review-input" autocomplete="off" placeholder="${placeholderText}" />
            ${!detail.englishAnswer ? `<div class="accent-buttons">
              ${["á", "é", "í", "ó", "ú", "ñ", "Á", "É", "Í", "Ó", "Ú", "Ñ"].map((char) =>
                `<button class="accent-btn" type="button" data-review-accent="${escAttr(char)}">${esc(char)}</button>`,
              ).join("")}
            </div>` : ""}
          </div>`;
        }

        html += `<button class="btn-next" type="button" data-review-check disabled>Check Answer</button>
          <div class="miss-review-feedback" data-review-feedback hidden></div>`;
        return html;
      }

      function setReviewReady(isReady) {
        const button = missReviewBody?.querySelector("[data-review-check]");
        if (!button) return;
        button.disabled = !isReady;
        button.classList.toggle("ready", isReady);
      }

      function closeMissReview() {
        if (!missReview) return;
        missReview.hidden = true;
        document.body.classList.remove("miss-review-open");
        activeReview = null;
        activeReviewAnswer = "";
      }

      function renderClearedMissState() {
        const list = document.getElementById("recent-misses");
        if (list && !list.querySelector("[data-miss-key]")) {
          list.innerHTML = `<p class="empty">Nice work. Cleared misses will stay off this dashboard.</p>`;
        }
      }

      function clearActiveMiss() {
        if (!activeReview) return;
        clearedMisses.add(activeReview.key);
        saveClearedMisses();
        document.querySelectorAll("[data-miss-key]").forEach((card) => {
          if (card.dataset.missKey === activeReview.key) card.remove();
        });
        renderClearedMissState();
      }

      function markReviewChoice(letter) {
        activeReviewAnswer = letter;
        missReviewBody?.querySelectorAll("[data-review-choice]").forEach((button) => {
          button.classList.toggle("sel", button.dataset.reviewChoice === letter);
        });
        setReviewReady(true);
      }

      function showReviewResult(isCorrect) {
        if (!activeReview) return;
        const detail = activeReview.detail;
        const feedback = missReviewBody?.querySelector("[data-review-feedback]");
        const button = missReviewBody?.querySelector("[data-review-check]");
        const correctAnswer = answerDisplay(detail);

        if (detail.type === "mc") {
          missReviewBody?.querySelectorAll("[data-review-choice]").forEach((choiceButton) => {
            const value = choiceButton.dataset.reviewChoice;
            choiceButton.disabled = true;
            if (value === detail.correct) choiceButton.classList.add("correct");
            if (value === activeReviewAnswer && value !== detail.correct) choiceButton.classList.add("wrong");
          });
        } else {
          const input = missReviewBody?.querySelector("#miss-review-input");
          if (input) input.disabled = true;
        }

        if (button) {
          button.textContent = "Return to Analytics";
          button.disabled = false;
          button.classList.add("ready");
          button.dataset.reviewDone = "true";
        }

        if (feedback) {
          feedback.hidden = false;
          feedback.className = `miss-review-feedback ${isCorrect ? "good" : "bad"}`;
          feedback.innerHTML = isCorrect
            ? "Correct. This miss has been cleared from your dashboard."
            : `Not quite. Answer: <strong>${esc(correctAnswer)}</strong>${detail.explanation ? `<br />${esc(detail.explanation)}` : ""}<br />Try this one again later.`;
        }

        if (isCorrect) clearActiveMiss();
      }

      function checkReviewAnswer() {
        if (!activeReview) return;
        const detail = activeReview.detail;
        const button = missReviewBody?.querySelector("[data-review-check]");
        if (button?.dataset.reviewDone === "true") {
          closeMissReview();
          return;
        }

        const input = missReviewBody?.querySelector("#miss-review-input");
        const answer = detail.type === "mc" ? activeReviewAnswer : (input?.value || "");
        const correctValues = detail.type === "mc" ? [detail.correct] : (detail.answers || []);
        const isCorrect = correctValues.some((value) => normalizeAnswer(value) === normalizeAnswer(answer));
        showReviewResult(isCorrect);
      }

      function insertReviewAccent(char) {
        const input = missReviewBody?.querySelector("#miss-review-input");
        if (!input) return;
        const start = input.selectionStart || 0;
        const end = input.selectionEnd || 0;
        input.value = input.value.slice(0, start) + char + input.value.slice(end);
        input.selectionStart = input.selectionEnd = start + char.length;
        input.focus();
        setReviewReady(input.value.trim().length > 0);
      }

      function openMissReview(index) {
        const review = reviewMisses[index];
        if (!review?.detail || !missReview || !missReviewBody) return;
        activeReview = review;
        activeReviewAnswer = "";
        if (missReviewTitle) missReviewTitle.textContent = `Question ${review.question.id}`;
        if (missReviewMeta) missReviewMeta.textContent = `${review.attempt.testTitle} - ${review.detail.type === "mc" ? "Multiple choice" : "Free response"}`;
        missReviewBody.innerHTML = reviewQuestionHtml(review);
        missReview.hidden = false;
        document.body.classList.add("miss-review-open");
        setReviewReady(false);
        missReviewBody.querySelector("#miss-review-input")?.focus();
      }

      function bindMissReviewHandlers() {
        document.querySelectorAll("[data-miss-open]").forEach((card) => {
          card.addEventListener("click", () => openMissReview(Number(card.dataset.missOpen)));
        });
      }

      function renderMisses(attempts) {
        const misses = [];
        sortRecent(attempts).forEach((attempt) => {
          (attempt.questionResults || []).forEach((question) => {
            if (!question.correct && !clearedMisses.has(missKey(attempt, question))) {
              misses.push({ attempt, question });
            }
          });
        });

        reviewMisses = [];
        const items = misses.slice(0, 8).map(({ attempt, question }) => {
          const test = testsBySlug.get(attempt.testSlug);
          const detail = getQuestionDetail(attempt, question);
          const key = missKey(attempt, question);
          const href = withReviewParam(test?.href, question.id);
          if (!detail) {
            return `<article class="miss-card" data-miss-key="${esc(key)}">
              <div>
                <div class="mini-title">${esc(question.section)}</div>
                <div class="mini-sub">${esc(attempt.testTitle)} - Question ${esc(question.id)} - ${esc(question.type)}</div>
              </div>
              <p class="miss-question">Open the test to review this legacy question.</p>
              <a class="miss-link" href="${esc(href)}">Open Review</a>
            </article>`;
          }

          const reviewIndex = reviewMisses.push({ attempt, question, detail, key, href }) - 1;
          return `<button class="miss-card" type="button" data-miss-key="${escAttr(key)}" data-miss-open="${reviewIndex}">
            <div>
              <div class="mini-title">${esc(question.section || detail.section)}</div>
              <div class="mini-sub">${esc(attempt.testTitle)} - Question ${esc(question.id)} - ${esc(question.type)}</div>
              <p class="miss-question">${esc(detail.prompt)}</p>
            </div>
            <span class="miss-open">Try Again</span>
          </button>`;
        });
        renderList("recent-misses", items, "Missed question tags will appear after saved attempts.");
        bindMissReviewHandlers();
      }

      function nextInSeries(test, attempted) {
        if (!test) return null;
        return tests.find((candidate) =>
          candidate.group === test.group
          && candidate.sequence > test.sequence
          && !attempted.has(candidate.slug)
        ) || tests.find((candidate) => candidate.slug === test.slug);
      }

      function firstUntakenInNextUnit(currentUnit, attempted) {
        const currentIndex = unitOrder.indexOf(currentUnit);
        if (currentIndex === -1) return null;
        for (let i = currentIndex + 1; i < unitOrder.length; i++) {
          const found = tests.find((test) => test.unit === unitOrder[i] && !attempted.has(test.slug));
          if (found) return found;
        }
        return null;
      }

      function renderRecommendations(attempts, weakSections, weakUnits) {
        const attempted = new Set(attempts.map((attempt) => attempt.testSlug));
        const recommendations = [];
        const seen = new Set();

        sortRecent(attempts)
          .filter((attempt) =>
            Number(attempt.percent) < 85
            || weakUnits.includes(attempt.unit)
            || (attempt.questionResults || []).some((question) => !question.correct),
          )
          .forEach((attempt) => {
            const source = testsBySlug.get(attempt.testSlug);
            const next = nextInSeries(source, attempted);
            if (next && !seen.has(next.slug)) {
              seen.add(next.slug);
              recommendations.push({
                test: next,
                chip: next.slug === source?.slug ? "Retry" : "Next",
                reason: `${attempt.testTitle} still has misses to clean up at ${Number(attempt.percent) || 0}%.`,
              });
            }
          });

        const masteredByUnit = new Map();
        attempts.forEach((attempt) => {
          if (Number(attempt.percent) >= 85) {
            masteredByUnit.set(attempt.unit, (masteredByUnit.get(attempt.unit) || 0) + 1);
          }
        });
        masteredByUnit.forEach((count, unit) => {
          if (count < 2) return;
          const nextUnitTest = firstUntakenInNextUnit(unit, attempted);
          if (nextUnitTest && !seen.has(nextUnitTest.slug)) {
            seen.add(nextUnitTest.slug);
            recommendations.push({
              test: nextUnitTest,
              chip: "Advance",
              reason: `${unit} has ${count} mastered attempts.`,
            });
          }
        });

        const items = recommendations.slice(0, 6).map(({ test, chip, reason }) => testCard(
          test,
          chip,
          `${reason} ${test.questionCount} questions.`,
        ));

        renderList(
          "recommendations",
          items,
          "No recommendations yet. Complete at least one test so Orange Atlas can recommend the next version, a retry, or the next unit.",
        );
      }

      function renderDashboard(attempts) {
        const attemptsSorted = sortRecent(attempts);
        const totalAttempts = attempts.length;
        const totalScore = attempts.reduce((sum, attempt) => sum + (Number(attempt.score) || 0), 0);
        const totalQuestions = attempts.reduce((sum, attempt) => sum + (Number(attempt.total) || 0), 0);
        const average = pct(totalScore, totalQuestions);
        const sections = aggregateSections(attempts);
        const units = aggregateUnits(attempts);
        const typeStats = aggregateObjectStats(attempts, "typeStats");
        const mediaStats = aggregateObjectStats(attempts, "mediaStats");
        const mastered = sections.filter((item) => item.total >= 8 && item.percent >= 85);
        const strictWeak = sections.filter((item) => item.total >= 5 && item.percent < 70);
        const focus = sections
          .filter((item) => item.total > item.correct)
          .sort((a, b) => {
            const misses = (b.total - b.correct) - (a.total - a.correct);
            return misses || a.percent - b.percent || b.total - a.total;
          });
        const focusByKey = new Map([...strictWeak, ...focus].map((item) => [item.key, item]));
        const weak = [...focusByKey.values()].sort((a, b) => {
          const misses = (b.total - b.correct) - (a.total - a.correct);
          return misses || a.percent - b.percent || b.total - a.total;
        });
        const weakUnits = units
          .filter((unit) => unit.total > unit.correct)
          .map((unit) => unit.key);

        document.getElementById("stat-attempts").textContent = String(totalAttempts);
        document.getElementById("stat-average").textContent = `${average}%`;
        document.getElementById("stat-mastered").textContent = String(mastered.length);
        document.getElementById("stat-focus").textContent = String(weak.length);

        renderTrend(attemptsSorted);
        renderList(
          "unit-list",
          units
            .sort((a, b) => unitOrder.indexOf(a.key) - unitOrder.indexOf(b.key))
            .map((item) => metricCard(item.key, `${item.correct}/${item.total} correct`, item.percent)),
          "Unit performance appears after saved attempts.",
        );
        renderList(
          "type-list",
          typeStats.map((item) => metricCard(item.key, `${item.correct}/${item.total} correct`, item.percent)),
          "Question-type performance appears after saved attempts.",
        );
        renderList(
          "media-list",
          mediaStats.map((item) => metricCard(item.key, `${item.correct}/${item.total} correct`, item.percent)),
          "Source and media performance appears after saved attempts.",
        );
        renderList(
          "mastered-list",
          mastered.slice(0, 8).map((item) => metricCard(item.key, `${item.correct}/${item.total} correct`, item.percent, "good")),
          "No mastered areas yet. 85%+ across 8 tagged questions will unlock this list.",
        );
        renderList(
          "weak-list",
          weak.slice(0, 8).map((item) => metricCard(item.key, `${item.correct}/${item.total} correct`, item.percent, "bad")),
          "No focus areas yet. More saved attempts will make this sharper.",
        );
        renderRecentAttempts(attemptsSorted);
        renderMisses(attemptsSorted);
        renderRecommendations(attemptsSorted, weak.map((item) => item.key), weakUnits);
      }

      function showGate(title, copy, canSignIn) {
        if (hero) hero.hidden = false;
        if (dashboard) dashboard.hidden = true;
        if (gate) gate.hidden = false;
        if (gateTitle) gateTitle.textContent = title;
        if (gateCopy) gateCopy.textContent = copy;
        if (gateSignin) gateSignin.hidden = !canSignIn;
      }

      async function loadAnalytics(userId = "local") {
        if (!isFirebaseConfigured()) {
          if (authState) authState.textContent = "Firebase setup needed";
          showGate("Firebase setup needed", "Add PUBLIC_FIREBASE_* values before Google sign-in and analytics can load.", false);
          return;
        }

        loadClearedMisses(userId);
        if (authState) authState.textContent = "Loading analytics";
        try {
          const attempts = await loadUserAttempts();
          if (hero) hero.hidden = true;
          if (gate) gate.hidden = true;
          if (dashboard) dashboard.hidden = false;
          if (authState) authState.textContent = `${attempts.length} saved attempt${attempts.length === 1 ? "" : "s"}`;
          renderDashboard(attempts);
        } catch (error) {
          console.warn("Unable to load Orange Atlas analytics", error);
          if (authState) authState.textContent = "Analytics failed to load";
          showGate("Analytics failed to load", "Check Firebase configuration and Firestore rules, then try again.", false);
        }
      }

      subscribeToAuth((user) => {
        if (!isFirebaseConfigured()) {
          if (authState) authState.textContent = "Firebase setup needed";
          showGate("Firebase setup needed", "Add PUBLIC_FIREBASE_* values before Google sign-in and analytics can load.", false);
          return;
        }

        if (!user) {
          loadClearedMisses("local");
          if (authState) authState.textContent = "Signed out";
          showGate("Sign in to view analytics", "Use Google sign-in to load saved attempts and progress insights.", true);
          return;
        }

        if (hero) hero.hidden = true;
        loadAnalytics(user.uid);
      });

      document.querySelector("[data-miss-return]")?.addEventListener("click", closeMissReview);
      missReviewBody?.addEventListener("click", (event) => {
        const target = event.target instanceof Element ? event.target : null;
        if (!target) return;

        const choice = target.closest("[data-review-choice]");
        if (choice) {
          markReviewChoice(choice.dataset.reviewChoice || "");
          return;
        }

        const accent = target.closest("[data-review-accent]");
        if (accent) {
          insertReviewAccent(accent.dataset.reviewAccent || "");
          return;
        }

        const check = target.closest("[data-review-check]");
        if (check) checkReviewAnswer();
      });
      missReviewBody?.addEventListener("input", (event) => {
        const target = event.target instanceof HTMLInputElement ? event.target : null;
        if (target?.matches("#miss-review-input")) {
          setReviewReady(target.value.trim().length > 0);
        }
      });
      missReviewBody?.addEventListener("keydown", (event) => {
        const target = event.target instanceof Element ? event.target : null;
        if (event.key === "Enter" && target?.matches("#miss-review-input")) {
          event.preventDefault();
          if (!missReviewBody.querySelector("[data-review-check]")?.disabled) checkReviewAnswer();
        }
      });
      window.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && missReview && !missReview.hidden) closeMissReview();
      });
    </script>
  </body>
</html>
