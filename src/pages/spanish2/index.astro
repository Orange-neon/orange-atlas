---
const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const iconHref = `${basePath}assets/orangeAtlas.png`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Spanish 2 practice tests and review sets for Orange Atlas.">
  <title>Spanish 2 Practice Hub | Orange Atlas</title>
  <link rel="icon" href={iconHref} type="image/png">
  <link rel="apple-touch-icon" href={iconHref}>
  <style>
    @import url("https://fonts.googleapis.com/css2?family=Besley:opsz,wght@6..32,600;6..32,800&family=Manrope:wght@400;500;700&display=swap");

    :root {
      --bg: #070b12;
      --bg-2: #0e1420;
      --panel: #131b2a;
      --panel-2: #162133;
      --line: rgba(168, 191, 230, 0.22);
      --text: #e7efff;
      --muted: #93a6c8;
      --aqua: #5fd0bb;
      --gold: #ffb86d;
      --rose: #ff8c86;
      --shadow: 0 20px 40px rgba(0, 0, 0, 0.45);
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      min-height: 100vh;
      font-family: "Manrope", sans-serif;
      color: var(--text);
      background:
        radial-gradient(60% 38% at 5% 8%, rgba(95, 208, 187, 0.2), transparent 62%),
        radial-gradient(55% 32% at 95% 0%, rgba(255, 184, 109, 0.2), transparent 58%),
        linear-gradient(180deg, var(--bg) 0%, var(--bg-2) 65%, #0a111d 100%);
      padding: 1.7rem 1.1rem 3rem;
    }

    .wrap {
      max-width: 1000px;
      margin: 0 auto;
    }

    .crumb {
      display: inline-flex;
      text-decoration: none;
      color: #9ac8ff;
      font-size: 0.9rem;
      font-weight: 700;
      margin-bottom: 1.1rem;
    }

    .crumb:hover {
      color: #c6e2ff;
      text-decoration: underline;
    }

    .hero {
      border: 1px solid var(--line);
      border-radius: 1.1rem;
      background: linear-gradient(155deg, var(--panel) 0%, var(--panel-2) 100%);
      box-shadow: var(--shadow);
      padding: 1.3rem 1.25rem;
      animation: rise 0.6s ease both;
    }

    .eyebrow {
      text-transform: uppercase;
      letter-spacing: 0.21em;
      font-size: 0.68rem;
      color: var(--muted);
      margin-bottom: 0.6rem;
    }

    h1 {
      font-family: "Besley", serif;
      font-size: clamp(2rem, 4.8vw, 3.4rem);
      line-height: 1.03;
      margin-bottom: 0.7rem;
    }

    .hero p {
      max-width: 62ch;
      color: #aab9d3;
      line-height: 1.72;
    }

    .stats {
      margin-top: 1rem;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.65rem;
    }

    .stat {
      border-radius: 0.75rem;
      border: 1px solid rgba(95, 208, 187, 0.28);
      background: rgba(7, 11, 18, 0.45);
      padding: 0.68rem 0.72rem;
    }

    .stat-value {
      font-family: "Besley", serif;
      font-size: 1.35rem;
      color: #91f8e5;
      line-height: 1;
      margin-bottom: 0.26rem;
    }

    .stat-label {
      color: var(--muted);
      font-size: 0.82rem;
    }

    .unit-title {
      margin: 1.55rem 0 0.65rem;
      font-family: "Besley", serif;
      font-size: 1.45rem;
    }

    .unit-list {
      display: grid;
      gap: 0.95rem;
    }

    .unit-card {
      border: 1px solid var(--line);
      border-radius: 1rem;
      background: linear-gradient(155deg, var(--panel) 0%, #101828 100%);
      padding: 1rem;
      animation: rise 0.6s ease both;
    }

    .unit-card + .unit-card {
      animation-delay: 0.12s;
    }

    .unit-head {
      display: flex;
      gap: 0.7rem;
      align-items: center;
      flex-wrap: wrap;
      margin-bottom: 0.85rem;
    }

    .unit-chip {
      border-radius: 999px;
      padding: 0.22rem 0.6rem;
      font-size: 0.67rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-weight: 700;
      border: 1px solid transparent;
    }

    .unit-chip.live {
      color: #91f8e5;
      border-color: rgba(95, 208, 187, 0.38);
      background: rgba(95, 208, 187, 0.13);
    }

    .unit-chip.pending {
      color: #ffd4a3;
      border-color: rgba(255, 184, 109, 0.4);
      background: rgba(255, 184, 109, 0.14);
    }

    .unit-name {
      font-family: "Besley", serif;
      font-size: 1.23rem;
      line-height: 1.15;
    }

    .unit-desc {
      color: var(--muted);
      font-size: 0.9rem;
      margin-bottom: 0.85rem;
      line-height: 1.62;
    }

    .subsection {
      margin-top: 1rem;
      padding-top: 0.95rem;
      border-top: 1px solid rgba(168, 191, 230, 0.16);
    }

    .subsection:first-of-type {
      margin-top: 0;
      padding-top: 0;
      border-top: none;
    }

    .subsection-title {
      font-family: "Besley", serif;
      font-size: 1rem;
      margin-bottom: 0.3rem;
    }

    .subsection-note {
      color: var(--muted);
      font-size: 0.84rem;
      line-height: 1.55;
      margin-bottom: 0.75rem;
    }

    .test-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 0.7rem;
    }

    .test-card {
      border: 1px solid rgba(168, 191, 230, 0.2);
      border-radius: 0.8rem;
      background: rgba(6, 11, 20, 0.5);
      padding: 0.82rem;
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
      text-decoration: none;
      color: inherit;
    }

    .test-card.live {
      border-color: rgba(95, 208, 187, 0.42);
      transition: transform 0.18s ease, border-color 0.18s ease;
    }

    .test-card.live:hover {
      transform: translateY(-2px);
      border-color: rgba(95, 208, 187, 0.65);
    }

    .test-name {
      font-family: "Besley", serif;
      font-size: 1.06rem;
    }

    .test-note {
      font-size: 0.86rem;
      color: var(--muted);
      line-height: 1.55;
    }

    .open {
      color: var(--aqua);
      font-size: 0.88rem;
      font-weight: 700;
    }

    .test-card.pending .open {
      color: var(--gold);
    }

    .roadmap {
      margin-top: 1.4rem;
      padding-top: 1rem;
      border-top: 1px solid var(--line);
      color: var(--muted);
      line-height: 1.66;
      font-size: 0.91rem;
    }

    .roadmap strong {
      color: var(--rose);
    }

    @keyframes rise {
      from {
        opacity: 0;
        transform: translateY(18px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 760px) {
      .stats {
        grid-template-columns: 1fr;
      }
    }

    :root {
      --bg: #030303;
      --bg-2: #0b0b0d;
      --panel: rgba(17, 17, 17, 0.76);
      --panel-2: rgba(24, 24, 24, 0.9);
      --line: rgba(255, 255, 255, 0.13);
      --line-strong: rgba(255, 116, 51, 0.42);
      --text: #faf8f5;
      --muted: #bbb4ad;
      --subtle: #827970;
      --aqua: #2dd4bf;
      --gold: #ffb86d;
      --rose: #ff8c86;
      --primary: #ff7433;
      --primary-glow: #ff9a5f;
      --shadow: 0 24px 70px rgba(0, 0, 0, 0.42);
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      color: var(--text);
      background:
        radial-gradient(ellipse 70% 44% at 50% 0%, rgba(255, 116, 51, 0.22), transparent 64%),
        linear-gradient(180deg, #000 0%, var(--bg) 48%, var(--bg-2) 100%);
      padding: 0 1rem 3.5rem;
      letter-spacing: 0;
    }

    .site-nav,
    .wrap {
      max-width: 1160px;
      margin: 0 auto;
    }

    .site-nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding: 1rem 0;
    }

    .brand,
    .home-link,
    .quick-links a {
      min-height: 2.65rem;
      display: inline-flex;
      align-items: center;
      text-decoration: none;
      font-weight: 800;
    }

    .brand {
      gap: 0.7rem;
      color: var(--text);
    }

    .brand-mark {
      width: 2.25rem;
      height: 2.25rem;
      border-radius: 0.5rem;
      display: grid;
      place-items: center;
      background: linear-gradient(135deg, var(--primary), #ffb86d);
      box-shadow: 0 0 26px rgba(255, 116, 51, 0.4);
      overflow: hidden;
    }

    .brand-mark img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .brand-name,
    .text-gradient {
      background: linear-gradient(135deg, var(--primary-glow), #ffd1a6 52%, #f8f7f4);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .home-link,
    .quick-links a {
      border: 1px solid var(--line);
      border-radius: 0.5rem;
      color: var(--muted);
      background: rgba(255, 255, 255, 0.04);
      transition: border-color 0.18s ease, color 0.18s ease, background 0.18s ease, transform 0.18s ease;
    }

    .home-link {
      padding: 0 0.9rem;
      font-size: 0.9rem;
    }

    .home-link:hover,
    .quick-links a:hover {
      color: var(--text);
      border-color: var(--line-strong);
      background: rgba(255, 116, 51, 0.11);
      transform: translateY(-1px);
    }

    .crumb {
      display: none;
    }

    .hero {
      border: 0;
      border-radius: 0;
      background: transparent;
      box-shadow: none;
      text-align: center;
      padding: 4.2rem 0 3.2rem;
      animation: rise 0.5s ease both;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      min-height: 2.4rem;
      border: 1px solid rgba(255, 116, 51, 0.3);
      border-radius: 999px;
      background: rgba(17, 17, 17, 0.68);
      color: #ffd1a6;
      padding: 0 1rem;
      letter-spacing: 0.16em;
      margin-bottom: 1.15rem;
    }

    h1 {
      font-family: "Besley", Georgia, serif;
      font-size: 2.7rem;
      line-height: 1;
      letter-spacing: 0;
      max-width: 780px;
      margin: 0 auto 1rem;
    }

    .hero p:not(.eyebrow) {
      color: var(--muted);
      font-size: 1.06rem;
      line-height: 1.75;
      max-width: 700px;
      margin: 0 auto;
    }

    .quick-links {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.65rem;
      margin-top: 1.5rem;
    }

    .quick-links a {
      padding: 0 0.88rem;
      font-size: 0.86rem;
    }

    .stats {
      max-width: 760px;
      margin: 1.65rem auto 0;
      gap: 0.75rem;
    }

    .stat,
    .unit-card,
    .test-card {
      border-radius: 0.5rem;
    }

    .stat {
      border-color: rgba(255, 116, 51, 0.28);
      background: rgba(255, 255, 255, 0.045);
      padding: 0.9rem;
    }

    .stat-value {
      color: #ffd1a6;
      font-size: 1.55rem;
    }

    .stat-label {
      color: var(--muted);
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .unit-title {
      margin: 2rem 0 0.9rem;
      padding-top: 0.9rem;
      border-top: 1px solid var(--line);
      font-family: "Besley", Georgia, serif;
      font-size: 1.8rem;
      line-height: 1.15;
      letter-spacing: 0;
    }

    .unit-list {
      gap: 1rem;
    }

    .unit-card {
      border-color: var(--line);
      background: linear-gradient(145deg, var(--panel) 0%, rgba(10, 10, 12, 0.88) 100%);
      box-shadow: 0 18px 45px rgba(0, 0, 0, 0.28);
      padding: 1.1rem;
    }

    .unit-head {
      justify-content: space-between;
      align-items: flex-start;
      gap: 0.8rem;
      margin-bottom: 0.7rem;
    }

    .unit-chip {
      border-radius: 999px;
      padding: 0.3rem 0.66rem;
      letter-spacing: 0.08em;
      order: 2;
    }

    .unit-chip.live {
      color: #ffd1a6;
      border-color: rgba(255, 116, 51, 0.42);
      background: rgba(255, 116, 51, 0.12);
    }

    .unit-name {
      font-family: "Besley", Georgia, serif;
      font-size: 1.28rem;
      letter-spacing: 0;
      order: 1;
      flex: 1 1 18rem;
    }

    .unit-desc {
      color: var(--muted);
      margin-bottom: 0.95rem;
      max-width: 72ch;
    }

    .subsection {
      border-top-color: var(--line);
      margin-top: 1.15rem;
    }

    .subsection-title {
      color: #ffd1a6;
      letter-spacing: 0;
    }

    .subsection-note {
      color: var(--muted);
      max-width: 76ch;
    }

    .test-grid {
      grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
      gap: 0.75rem;
    }

    .test-card {
      border-color: rgba(255, 255, 255, 0.12);
      background: rgba(255, 255, 255, 0.04);
      min-height: 9.4rem;
      padding: 0.92rem;
      transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease;
    }

    .test-card.live {
      border-color: rgba(255, 116, 51, 0.24);
    }

    .test-card.live:hover {
      transform: translateY(-2px);
      border-color: rgba(255, 116, 51, 0.62);
      background: rgba(255, 116, 51, 0.09);
    }

    .test-name {
      font-family: "Besley", Georgia, serif;
      font-size: 1.03rem;
      letter-spacing: 0;
    }

    .test-note {
      color: var(--muted);
      line-height: 1.55;
      flex: 1;
    }

    .open {
      color: #ffd1a6;
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .roadmap {
      display: none;
    }

    @media (min-width: 768px) {
      h1 {
        font-size: 4.35rem;
      }

      .hero {
        padding-top: 5.25rem;
      }

      .unit-card {
        padding: 1.25rem;
      }
    }

    @media (max-width: 640px) {
      body {
        padding-left: 0.9rem;
        padding-right: 0.9rem;
      }

      .site-nav {
        align-items: stretch;
        flex-direction: column;
      }

      .home-link {
        justify-content: center;
      }

      .hero {
        text-align: left;
        padding: 2rem 0 2.1rem;
      }

      h1,
      .hero p:not(.eyebrow) {
        margin-left: 0;
      }

      .quick-links {
        justify-content: flex-start;
      }

      .quick-links a {
        flex: 1 1 8rem;
        justify-content: center;
      }

      .unit-head {
        display: grid;
      }

      .unit-chip {
        order: 1;
        justify-self: start;
      }

      .unit-name {
        order: 2;
      }
    }
  </style>
</head>
<body>
  <nav class="site-nav" aria-label="Course navigation">
    <a class="brand" href="../" aria-label="Orange Atlas home">
      <span class="brand-mark"><img src={iconHref} alt="" loading="eager"></span>
      <span class="brand-name">Orange Atlas</span>
    </a>
    <a class="home-link" href="../">All Courses</a>
  </nav>

  <main class="wrap">
    <a class="crumb" href="../" aria-label="Back to all courses">&larr; All Courses</a>

    <section class="hero">
      <p class="eyebrow">Spanish 2 Course Home</p>
      <h1><span class="text-gradient">Spanish 2</span> Practice Hub</h1>
      <p>
        Practice tests are organized by unit, with dedicated grammar review and a semester-two practice final for cumulative prep.
      </p>
      <nav class="quick-links" aria-label="Spanish 2 sections">
        <a href="#units">Units</a>
        <a href="#mandatos">Mandatos</a>
        <a href="#por-para">Por vs. Para</a>
        <a href="#final-review">Final Review</a>
      </nav>
      <div class="stats" aria-label="Course quick stats">
        <div class="stat">
          <p class="stat-value">3</p>
          <p class="stat-label">Active units</p>
        </div>
        <div class="stat">
          <p class="stat-value">43</p>
          <p class="stat-label">Live test sets</p>
        </div>
        <div class="stat">
          <p class="stat-value">920</p>
          <p class="stat-label">Questions across live exams</p>
        </div>
      </div>
    </section>

    <h2 id="units" class="unit-title">Units</h2>
    <section class="unit-list" aria-label="Spanish 2 units and tests">
      <article class="unit-card">
        <div class="unit-head">
          <span class="unit-chip live">Live Unit</span>
          <h3 class="unit-name">Unidad 4 - En el Consultorio</h3>
        </div>
        <p class="unit-desc">Health, doctor visit vocabulary, and interpretive reading practice connected to Unit 4 themes.</p>
        <div class="test-grid">
          <a class="test-card live" href="./unidad-4-en-el-consultorio/interpretive-1.html">
            <h4 class="test-name">Interpretive 1</h4>
            <p class="test-note">Lectura interpretiva set for En el Consultorio with 20 questions and a 25-minute limit.</p>
            <p class="open">Start Test -></p>
          </a>
        </div>
      </article>

      <article class="unit-card">
        <div class="unit-head">
          <span class="unit-chip live">Live Unit</span>
          <h3 class="unit-name">Unidad 5 - La Tecnolog&iacute;a</h3>
        </div>
        <p class="unit-desc">Technology and car vocabulary, reading comprehension, and mixed grammar review.</p>
        <div class="subsection">
          <h4 class="subsection-title">Core Practice</h4>
          <p class="subsection-note">Main La Tecnolog&iacute;a test sets covering vocabulary, grammar, and mixed review.</p>
          <div class="test-grid">
            <a class="test-card live" href="./unidad-5-la-tecnologia/la-tecnologia-1.html">
              <h4 class="test-name">La Tecnolog&iacute;a 1</h4>
              <p class="test-note">Integrated exam for Senderos 2 Lesson 5 practice.</p>
              <p class="open">Start Test -></p>
            </a>
            <a class="test-card live" href="./unidad-5-la-tecnologia/la-tecnologia-2.html">
              <h4 class="test-name">La Tecnolog&iacute;a 2</h4>
              <p class="test-note">Advanced exam for Senderos 2 Lesson 5 with higher rigor and mixed challenge formats.</p>
              <p class="open">Start Test -></p>
            </a>
            <a class="test-card live" href="./unidad-5-la-tecnologia/la-tecnologia-3.html">
              <h4 class="test-name">La Tecnolog&iacute;a 3</h4>
              <p class="test-note">Third exam set for Senderos 2 Lesson 5 with cumulative mixed-format review.</p>
              <p class="open">Start Test -></p>
            </a>
            <a class="test-card live" href="./unidad-5-la-tecnologia/la-tecnologia-4.html">
              <h4 class="test-name">La Tecnolog&iacute;a 4</h4>
              <p class="test-note">Timed exam format with 20 questions and a 17-minute limit.</p>
              <p class="open">Start Test -></p>
            </a>
            <a class="test-card live" href="./unidad-5-la-tecnologia/la-tecnologia-5.html">
              <h4 class="test-name">La Tecnolog&iacute;a 5</h4>
              <p class="test-note">Additional timed exam with 20 questions and a 17-minute limit.</p>
              <p class="open">Start Test -></p>
            </a>
            <a class="test-card live" href="./unidad-5-la-tecnologia/la-tecnologia-6.html">
              <h4 class="test-name">La Tecnolog&iacute;a 6</h4>
              <p class="test-note">Timed exam format with 20 questions and a 17-minute limit.</p>
              <p class="open">Start Test -></p>
            </a>
            <a class="test-card live" href="./unidad-5-la-tecnologia/la-tecnologia-7.html">
              <h4 class="test-name">La Tecnolog&iacute;a 7</h4>
              <p class="test-note">Timed exam format with 20 questions and a 17-minute limit.</p>
              <p class="open">Start Test -></p>
            </a>
            <a class="test-card live" href="./unidad-5-la-tecnologia/la-tecnologia-8.html">
              <h4 class="test-name">La Tecnolog&iacute;a 8</h4>
              <p class="test-note">Timed exam format with 20 questions and a 17-minute limit.</p>
              <p class="open">Start Test -></p>
            </a>
            <a class="test-card live" href="./unidad-5-la-tecnologia/la-tecnologia-9.html">
              <h4 class="test-name">La Tecnolog&iacute;a 9</h4>
              <p class="test-note">Timed exam format with 20 questions and a 17-minute limit.</p>
              <p class="open">Start Test -></p>
            </a>
            <a class="test-card live" href="./unidad-5-la-tecnologia/la-tecnologia-10.html">
              <h4 class="test-name">La Tecnolog&iacute;a 10</h4>
              <p class="test-note">Timed exam format with 20 questions and a 17-minute limit.</p>
              <p class="open">Start Test -></p>
            </a>
            <a class="test-card live" href="./unidad-5-la-tecnologia/la-tecnologia-11.html">
              <h4 class="test-name">La Tecnolog&iacute;a 11</h4>
              <p class="test-note">Timed exam format with 20 questions and a 17-minute limit.</p>
              <p class="open">Start Test -></p>
            </a>
            <a class="test-card live" href="./unidad-5-la-tecnologia/la-tecnologia-12.html">
              <h4 class="test-name">La Tecnolog&iacute;a 12</h4>
              <p class="test-note">Timed exam format with 20 questions and a 17-minute limit.</p>
              <p class="open">Start Test -></p>
