<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Spanish 2 Practice Hub</title>
  <link rel="icon" href="/orange-atlas/assets/orangeAtlas.png" type="image/png">
  <style>
    @import url("https://fonts.googleapis.com/css2?family=Besley:opsz,wght@6..32,600;6..32,800&family=Manrope:wght@400;500;700&display=swap");

    :root {
      --bg: #070b12;
      --bg-2: #0e1420;
      --panel: #131b2a;
      --panel-2: #162133;
      --line: rgba(168, 191, 230, 0.22);
      --text: #e7efff;
      --muted: #93a6c8;
      --aqua: #5fd0bb;
      --gold: #ffb86d;
      --rose: #ff8c86;
      --shadow: 0 20px 40px rgba(0, 0, 0, 0.45);
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      min-height: 100vh;
      font-family: "Manrope", sans-serif;
      color: var(--text);
      background:
        radial-gradient(60% 38% at 5% 8%, rgba(95, 208, 187, 0.2), transparent 62%),
        radial-gradient(55% 32% at 95% 0%, rgba(255, 184, 109, 0.2), transparent 58%),
        linear-gradient(180deg, var(--bg) 0%, var(--bg-2) 65%, #0a111d 100%);
      padding: 1.7rem 1.1rem 3rem;
    }

    .wrap {
      max-width: 1000px;
      margin: 0 auto;
    }

    .crumb {
      display: inline-flex;
      text-decoration: none;
      color: #9ac8ff;
      font-size: 0.9rem;
      font-weight: 700;
      margin-bottom: 1.1rem;
    }

    .crumb:hover {
      color: #c6e2ff;
      text-decoration: underline;
    }

    .hero {
      border: 1px solid var(--line);
      border-radius: 1.1rem;
      background: linear-gradient(155deg, var(--panel) 0%, var(--panel-2) 100%);
      box-shadow: var(--shadow);
      padding: 1.3rem 1.25rem;
      animation: rise 0.6s ease both;
    }

    .eyebrow {
      text-transform: uppercase;
      letter-spacing: 0.21em;
      font-size: 0.68rem;
      color: var(--muted);
      margin-bottom: 0.6rem;
    }

    h1 {
      font-family: "Besley", serif;
      font-size: clamp(2rem, 4.8vw, 3.4rem);
      line-height: 1.03;
      margin-bottom: 0.7rem;
    }

    .hero p {
      max-width: 62ch;
      color: #aab9d3;
      line-height: 1.72;
    }

    .stats {
      margin-top: 1rem;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.65rem;
    }

    .stat {
      border-radius: 0.75rem;
      border: 1px solid rgba(95, 208, 187, 0.28);
      background: rgba(7, 11, 18, 0.45);
      padding: 0.68rem 0.72rem;
    }

    .stat-value {
      font-family: "Besley", serif;
      font-size: 1.35rem;
      color: #91f8e5;
      line-height: 1;
      margin-bottom: 0.26rem;
    }

    .stat-label {
      color: var(--muted);
      font-size: 0.82rem;
    }

    .unit-title {
      margin: 1.55rem 0 0.65rem;
      font-family: "Besley", serif;
      font-size: 1.45rem;
    }

    .unit-list {
      display: grid;
      gap: 0.95rem;
    }

    .unit-card {
      border: 1px solid var(--line);
      border-radius: 1rem;
      background: linear-gradient(155deg, var(--panel) 0%, #101828 100%);
      padding: 1rem;
      animation: rise 0.6s ease both;
    }

    .unit-card + .unit-card {
      animation-delay: 0.12s;
    }

    .unit-head {
      display: flex;
      gap: 0.7rem;
      align-items: center;
      flex-wrap: wrap;
      margin-bottom: 0.85rem;
    }

    .unit-chip {
      border-radius: 999px;
      padding: 0.22rem 0.6rem;
      font-size: 0.67rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-weight: 700;
      border: 1px solid transparent;
    }

    .unit-chip.live {
      color: #91f8e5;
      border-color: rgba(95, 208, 187, 0.38);
      background: rgba(95, 208, 187, 0.13);
    }

    .unit-chip.pending {
      color: #ffd4a3;
      border-color: rgba(255, 184, 109, 0.4);
      background: rgba(255, 184, 109, 0.14);
    }

    .unit-name {
      font-family: "Besley", serif;
      font-size: 1.23rem;
      line-height: 1.15;
    }

    .unit-desc {
      color: var(--muted);
      font-size: 0.9rem;
      margin-bottom: 0.85rem;
      line-height: 1.62;
    }

    .subsection {
      margin-top: 1rem;
      padding-top: 0.95rem;
      border-top: 1px solid rgba(168, 191, 230, 0.16);
    }

    .subsection:first-of-type {
      margin-top: 0;
      padding-top: 0;
      border-top: none;
    }

    .subsection-title {
      font-family: "Besley", serif;
      font-size: 1rem;
      margin-bottom: 0.3rem;
    }

    .subsection-note {
      color: var(--muted);
      font-size: 0.84rem;
      line-height: 1.55;
      margin-bottom: 0.75rem;
    }

    .test-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 0.7rem;
    }

    .test-card {
      border: 1px solid rgba(168, 191, 230, 0.2);
      border-radius: 0.8rem;
      background: rgba(6, 11, 20, 0.5);
      padding: 0.82rem;
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
      text-decoration: none;
      color: inherit;
    }

    .test-card.live {
      border-color: rgba(95, 208, 187, 0.42);
      transition: transform 0.18s ease, border-color 0.18s ease;
    }

    .test-card.live:hover {
      transform: translateY(-2px);
      border-color: rgba(95, 208, 187, 0.65);
    }

    .test-name {
      font-family: "Besley", serif;
      font-size: 1.06rem;
    }

    .test-note {
      font-size: 0.86rem;
      color: var(--muted);
      line-height: 1.55;
    }

    .open {
      color: var(--aqua);
      font-size: 0.88rem;
      font-weight: 700;
    }

    .test-card.pending .open {
      color: var(--gold);
    }

    .roadmap {
      margin-top: 1.4rem;
      padding-top: 1rem;
      border-top: 1px solid var(--line);
      color: var(--muted);
      line-height: 1.66;
      font-size: 0.91rem;
    }

    .roadmap strong {
      color: var(--rose);
    }

    @keyframes rise {
      from {
        opacity: 0;
        transform: translateY(18px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 760px) {
      .stats {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
