{
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "dist",
    "predeploy": [
      "npm run build:firebase"
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/orange-atlas",
        "destination": "/",
        "type": 301
      },
      {
        "regex": "/orange-atlas/(.*)",
        "destination": "/:1",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/api/chat",
        "function": {
          "functionId": "chat",
          "region": "us-central1"
        }
      }
    ]
  }
}
